<%- include('partials/header', { page_title: 'Super Admin — MuniPro' }) %>

<style>
  .admin-login-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, #0a0a1a 0%, #1a1a2e 40%, #16213e 100%);
    position: relative;
    overflow: hidden;
  }
  .admin-login-page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(124,58,237,0.25) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(0,63,136,0.3) 0%, transparent 60%);
    pointer-events: none;
  }
  .admin-card {
    width: 420px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    backdrop-filter: blur(20px);
    padding: 48px 40px;
    position: relative;
    z-index: 1;
    box-shadow: 0 32px 80px rgba(0,0,0,0.6);
  }
  .admin-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(124,58,237,0.2);
    border: 1px solid rgba(124,58,237,0.4);
    border-radius: 20px;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 700;
    color: #c4b5fd;
    letter-spacing: 0.5px;
    margin-bottom: 24px;
  }
  .admin-title { font-size: 28px; font-weight: 800; color: white; margin-bottom: 6px; }
  .admin-sub { font-size: 14px; color: rgba(255,255,255,0.5); margin-bottom: 32px; }
  .admin-input {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 14px 16px;
    font-size: 15px;
    color: white;
    width: 100%;
    outline: none;
    transition: all .2s;
    font-family: inherit;
  }
  .admin-input:focus {
    border-color: #7c3aed;
    box-shadow: 0 0 0 3px rgba(124,58,237,0.2);
    background: rgba(255,255,255,0.09);
  }
  .admin-input::placeholder { color: rgba(255,255,255,0.3); }
  .admin-label { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.7); display: block; margin-bottom: 8px; }
  .btn-admin { 
    width: 100%;
    background: linear-gradient(135deg, #7c3aed, #6d28d9);
    border: none; border-radius: 12px;
    padding: 15px; color: white;
    font-size: 16px; font-weight: 700;
    cursor: pointer; transition: all .2s;
    display: flex; align-items: center; justify-content: center; gap: 10px;
  }
  .btn-admin:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(124,58,237,.45); }
  .back-link { display: block; text-align: center; margin-top: 20px; font-size: 13px; color: rgba(255,255,255,0.4); }
  .back-link a { color: rgba(255,255,255,0.6); text-decoration: none; }
  .back-link a:hover { color: white; }
  /* Floating particles */
  .particle {
    position: absolute;
    border-radius: 50%;
    animation: float linear infinite;
    opacity: 0.15;
    pointer-events: none;
  }
  @keyframes float {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.15; }
    90% { opacity: 0.15; }
    100% { transform: translateY(-100px) rotate(720deg); opacity: 0; }
  }
</style>

<div class="admin-login-page" id="adminLoginPage">
  <!-- Particules -->
  <div class="particle" style="width:4px;height:4px;background:#7c3aed;left:10%;animation-duration:12s;animation-delay:0s;"></div>
  <div class="particle" style="width:6px;height:6px;background:#003F88;left:25%;animation-duration:18s;animation-delay:2s;"></div>
  <div class="particle" style="width:3px;height:3px;background:#7c3aed;left:50%;animation-duration:14s;animation-delay:5s;"></div>
  <div class="particle" style="width:5px;height:5px;background:#0ea5e9;left:70%;animation-duration:16s;animation-delay:1s;"></div>
  <div class="particle" style="width:4px;height:4px;background:#7c3aed;left:85%;animation-duration:20s;animation-delay:3s;"></div>

  <div class="admin-card">
    <div class="admin-badge">
      <i class="bi bi-shield-fill-check"></i> SUPER ADMINISTRATEUR
    </div>
    <h1 class="admin-title">MuniPro Admin</h1>
    <p class="admin-sub">Accès restreint — Zone sécurisée niveau 2</p>

    <% if (erreur) { %>
    <div style="background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.3);border-radius:10px;padding:12px 16px;margin-bottom:24px;display:flex;gap:10px;align-items:center;">
      <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;"></i>
      <span style="color:#fca5a5;font-size:14px;"><%= e(erreur) %></span>
    </div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div style="margin-bottom:18px;">
        <label class="admin-label"><i class="bi bi-envelope me-1"></i>Email Administrateur</label>
        <input type="email" name="email" class="admin-input" placeholder="admin@munipro.cm" value="<%= e(body.email||'') %>" required autofocus>
      </div>
      <div style="margin-bottom:28px;">
        <label class="admin-label"><i class="bi bi-key me-1"></i>Mot de passe sécurisé</label>
        <div style="position:relative;">
          <input type="password" id="admin-password" name="password" class="admin-input" placeholder="••••••••••••" required style="padding-right: 40px;">
          <button type="button" onclick="togglePassword('admin-password', this)" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; color:rgba(255,255,255,0.5); cursor:pointer; padding:0;">
            <i class="bi bi-eye"></i>
          </button>
        </div>
      </div>
      <button type="submit" class="btn-admin">
        <i class="bi bi-shield-lock-fill"></i> Accéder au Panneau Admin
      </button>
    </form>

    <div style="margin-top:24px;padding-top:20px;border-top:1px solid rgba(255,255,255,0.07);text-align:center;">
      <small style="color:rgba(255,255,255,0.3);font-size:12px;">
        <i class="bi bi-lock-fill me-1"></i>Connexion chiffrée · Session sécurisée
      </small>
    </div>
    <div class="back-link"><a href="/login">← Espace Communes (Responsables)</a></div>
  </div>
</div>

<script>
function togglePassword(inputId, btn) {
  var input = document.getElementById(inputId);
  var icon = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.remove('bi-eye');
    icon.classList.add('bi-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.remove('bi-eye-slash');
    icon.classList.add('bi-eye');
  }
}
</script>

<%- include('partials/footer') %>
