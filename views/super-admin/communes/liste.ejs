<%- include('../partials/header', { page_title: 'Communes' }) %>
<%- include('../partials/sidebar') %>

<div class="main-content">
  <div class="topbar">
    <div class="topbar-title"><i class="bi bi-building" style="color:var(--munipro-blue);margin-right:10px;"></i>Gestion des Communes</div>
    <a href="<%= siteUrl %>/communes/creer" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg"></i> Nouvelle Commune</a>
  </div>

  <div class="content-area">

    <!-- FILTRES -->
    <div class="card mb-6">
      <div class="card-body">
        <form method="GET" style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
          <div style="flex:1;min-width:200px;">
            <label class="form-label">Rechercher</label>
            <input type="text" name="search" class="form-control" placeholder="Nom de la commune..." value="<%= filtre.search || '' %>">
          </div>
          <div style="min-width:160px;">
            <label class="form-label">Statut</label>
            <select name="statut" class="form-select">
              <option value="">Tous les statuts</option>
              <option value="actif" <%= filtre.statut==='actif'?'selected':'' %>>✅ Actif</option>
              <option value="suspendu" <%= filtre.statut==='suspendu'?'selected':'' %>>⚠️ Suspendu</option>
              <option value="inactif" <%= filtre.statut==='inactif'?'selected':'' %>>❌ Inactif</option>
            </select>
          </div>
          <div style="min-width:160px;">
            <label class="form-label">Région</label>
            <select name="region" class="form-select">
              <option value="">Toutes les régions</option>
              <% regions.forEach(r => { %><option value="<%= e(r) %>" <%= filtre.region===r?'selected':'' %>><%= e(r) %></option><% }); %>
            </select>
          </div>
          <div style="display:flex;gap:8px;">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Filtrer</button>
            <a href="<%= siteUrl %>/communes" class="btn btn-outline"><i class="bi bi-x"></i> Réinitialiser</a>
          </div>
        </form>
      </div>
    </div>

    <!-- RÉSULTATS -->
    <% if (communes.length === 0) { %>
    <div class="card"><div class="empty-state"><i class="bi bi-building"></i>Aucune commune trouvée avec ces filtres.</div></div>
    <% } else { %>

    <!-- GRILLE COMMUNES -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:20px;margin-bottom:28px;">
      <% communes.forEach(c => { %>
      <div class="commune-card <%= c.statut %>">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;">
          <div>
            <h3 style="font-size:16px;font-weight:700;margin:0;"><%= e(c.nom) %></h3>
            <p style="color:var(--text-muted);font-size:12px;margin:2px 0 0;"><i class="bi bi-geo-alt"></i> <%= e(c.region) %></p>
          </div>
          <span class="badge badge-<%= c.statut %>"><%= c.statut %></span>
        </div>

        <div class="kpi-row mb-4">
          <div class="kpi-item">
            <div class="val"><%= c.total_projets %></div>
            <div class="lbl">Projets</div>
          </div>
          <div class="kpi-item">
            <div class="val" style="color:var(--munipro-green);"><%= c.termines || 0 %></div>
            <div class="lbl">Terminés</div>
          </div>
          <div class="kpi-item">
            <div class="val" style="color:<%= c.en_retard>0?'var(--munipro-red)':'var(--text)' %>;"><%= c.en_retard || 0 %></div>
            <div class="lbl">Retards</div>
          </div>
          <div class="kpi-item">
            <div class="val"><%= c.taux_avancement %>%</div>
            <div class="lbl">Avancement</div>
          </div>
        </div>

        <div style="margin-bottom:14px;">
          <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;">
            <span class="text-muted">Taux d'exécution</span>
            <span style="font-weight:700;"><%= c.taux_avancement %>%</span>
          </div>
          <div class="progress">
            <div class="progress-bar <%= c.taux_avancement > 70 ? 'low' : c.taux_avancement > 40 ? 'mid' : 'high' %>" style="width:<%= c.taux_avancement %>%;"></div>
          </div>
        </div>

        <div style="font-size:12px;color:var(--text-muted);margin-bottom:16px;">
          <div><i class="bi bi-person"></i> <%= e(c.responsable || '—') %></div>
          <div><i class="bi bi-envelope"></i> <%= e(c.email) %></div>
          <div><i class="bi bi-cash-stack"></i> <%= formatMontant(c.budget_total) %></div>
        </div>

        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <a href="<%= siteUrl %>/communes/<%= c.id %>" class="btn btn-primary btn-sm" style="flex:1;justify-content:center;"><i class="bi bi-eye"></i> Détails</a>
          <form method="POST" action="<%= siteUrl %>/communes/<%= c.id %>/toggle" style="margin:0;">
            <button type="submit" class="btn btn-sm <%= c.statut==='actif'?'btn-outline':'btn-success' %>">
              <i class="bi bi-<%= c.statut==='actif'?'pause':'play' %>-circle"></i>
              <%= c.statut==='actif'?'Suspendre':'Réactiver' %>
            </button>
          </form>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
