<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= projet.titre %> — Détails du projet municipal · Portail Citoyen des Communes du Littoral, République du Cameroun">
  <title><%= projet.titre %> — Portail Citoyen · République du Cameroun</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    :root {
      --vert: #007A3D; --vert-dark: #005C2E; --vert-light: #E8F5EE;
      --jaune: #FCD116; --rouge: #CE1126;
      --noir: #1A1A1A; --gris: #6C757D; --gris-clair: #F4F6F8;
      --blanc: #FFFFFF; --border: #DDE3EA;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Poppins', sans-serif; background: var(--gris-clair); color: var(--noir); }

    .tricolor-bar{display:flex;height:6px;}
    .tc-vert{flex:1;background:var(--vert);} .tc-jaune{flex:1;background:var(--jaune);} .tc-rouge{flex:1;background:var(--rouge);}

    .official-header{background:var(--blanc);border-bottom:3px solid var(--vert);padding:10px 32px;}
    .official-header .container{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;}
    .off-left{font-size:10px;font-weight:600;color:#2C3E50;text-transform:uppercase;}
    .off-left .fr-name{font-size:11px;font-weight:800;color:var(--vert-dark);}
    .off-left .motto{font-style:italic;color:var(--gris);font-weight:400;text-transform:none;font-size:9.5px;}
    .off-right{font-size:10px;text-align:right;color:#2C3E50;font-weight:600;}
    .off-center img{height:60px;filter:drop-shadow(0 2px 6px rgba(0,0,0,0.1));}
    .off-divider{width:1px;height:48px;background:var(--border);}
    @media(max-width:768px){.off-left,.off-right,.off-divider{display:none;}.official-header .container{justify-content:center;}}

    .main-nav{background:var(--vert-dark);padding:0 32px;position:sticky;top:0;z-index:1000;box-shadow:0 3px 12px rgba(0,0,0,0.2);}
    .nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:52px;}
    .nav-brand{display:flex;align-items:center;gap:10px;text-decoration:none;}
    .nav-brand img{height:30px;}
    .nav-brand span{color:var(--jaune);font-weight:800;font-size:14px;}
    .nav-breadcrumb{display:flex;align-items:center;gap:5px;font-size:12px;color:rgba(255,255,255,0.65);}
    .nav-breadcrumb a{color:rgba(255,255,255,0.6);text-decoration:none;transition:color .2s;}
    .nav-breadcrumb a:hover{color:var(--jaune);}
    .nav-breadcrumb .sep{opacity:0.4;}
    .nav-breadcrumb .cur{color:var(--jaune);font-weight:600;}
    .btn-retour{display:flex;align-items:center;gap:5px;color:rgba(255,255,255,0.7);font-size:11.5px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,0.2);padding:5px 12px;border-radius:20px;transition:all .2s;}
    .btn-retour:hover{color:#fff;border-color:rgba(255,255,255,0.5);}
    @media(max-width:768px){.nav-breadcrumb{display:none;}}

    /* HERO */
    .hero{
      min-height:340px;
      <%= projet.photo ? "background-image:url('" + imageUrl(projet.photo) + "');" : "" %>
      background-color:<%= heroColor %>;
      background-size:cover;background-position:center;
      position:relative;overflow:hidden;
      display:flex;align-items:flex-end;padding:48px 32px 36px;
    }
    .hero::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,92,46,0.85),rgba(0,40,20,0.7));}
    .hero::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.75) 0%,rgba(0,0,0,0.15) 60%,transparent 100%);}
    .hero-content{position:relative;z-index:2;max-width:900px;width:100%;}
    .hero-type-badge{display:inline-flex;align-items:center;gap:7px;background:rgba(252,209,22,0.15);border:1px solid rgba(252,209,22,0.45);color:var(--jaune);padding:6px 16px;border-radius:30px;font-size:10.5px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;}
    .hero h1{color:#fff;font-size:clamp(22px,4vw,40px);font-weight:900;line-height:1.2;margin-bottom:10px;}
    .hero-location{color:rgba(255,255,255,0.8);font-size:14px;display:flex;align-items:center;gap:6px;}

    /* STATUS BAR */
    .status-bar{background:var(--blanc);border-bottom:1px solid var(--border);padding:14px 32px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;box-shadow:0 2px 8px rgba(0,0,0,0.05);}
    .status-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:16px;flex-wrap:wrap;width:100%;}
    .statut-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 14px;border-radius:20px;font-size:12px;font-weight:700;}
    .sp-en_cours{background:rgba(0,122,61,0.1);color:var(--vert-dark);}
    .sp-terminé{background:rgba(0,122,61,0.1);color:var(--vert);}
    .sp-planifié{background:rgba(14,165,233,0.1);color:#0284C7;}
    .sp-suspendu{background:rgba(252,209,22,0.2);color:#854d0e;}
    .sp-annulé{background:rgba(206,17,38,0.1);color:var(--rouge);}
    .status-meta{color:var(--gris);font-size:13px;display:flex;align-items:center;gap:6px;}
    .status-meta:last-of-type{margin-left:auto;}

    /* MAIN LAYOUT */
    .main{max-width:1200px;margin:0 auto;padding:36px 32px 80px;display:grid;grid-template-columns:1fr 360px;gap:28px;}

    /* LEFT COLUMN */
    .card{background:var(--blanc);border-radius:14px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,0.05);overflow:hidden;margin-bottom:22px;}
    .card-header{padding:16px 22px;border-bottom:3px solid var(--vert);display:flex;align-items:center;gap:8px;background:var(--vert-light);}
    .card-header h3{font-size:14.5px;font-weight:700;margin:0;color:var(--vert-dark);}
    .card-body{padding:24px;}
    .description{font-size:13.5px;line-height:1.85;color:#2C3E50;}

    /* Progress */
    .progress-section{padding:22px 24px;}
    .progress-label{display:flex;justify-content:space-between;margin-bottom:8px;font-size:13px;align-items:center;}
    .progress-label .pct{font-size:18px;font-weight:900;}
    .prog-bar{height:14px;background:#E2E8F0;border-radius:10px;overflow:hidden;}
    .prog-fill{height:100%;border-radius:10px;transition:width .8s;}
    .prog-note{font-size:11px;color:var(--gris);margin-top:8px;}

    /* Photos */
    .photos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:10px;padding:16px;}
    .photo-item{border-radius:10px;overflow:hidden;aspect-ratio:4/3;}
    .photo-item img{width:100%;height:100%;object-fit:cover;transition:transform .3s;}
    .photo-item:hover img{transform:scale(1.06);}

    /* RIGHT SIDEBAR */
    .sidebar-card{background:var(--blanc);border-radius:14px;border:1px solid var(--border);padding:22px;margin-bottom:18px;box-shadow:0 2px 8px rgba(0,0,0,0.05);}
    .sidebar-card h4{font-size:13.5px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:6px;color:var(--vert-dark);padding-bottom:10px;border-bottom:2px solid var(--vert-light);}
    .kpi-stack{display:flex;flex-direction:column;gap:9px;}
    .kpi-row{display:flex;align-items:center;justify-content:space-between;padding:11px 14px;background:var(--gris-clair);border-radius:10px;border:1px solid var(--border);}
    .kpi-row .lbl{font-size:11.5px;color:var(--gris);font-weight:500;}
    .kpi-row .val{font-size:15px;font-weight:800;color:var(--vert-dark);}

    /* Timeline */
    .timeline{display:flex;flex-direction:column;gap:0;}
    .tl-item{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
    .tl-item:last-child{border-bottom:none;}
    .tl-dot{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:14px;}
    .tl-dot.green{background:rgba(0,122,61,0.12);color:var(--vert);}
    .tl-dot.yellow{background:rgba(252,209,22,0.2);color:#8B6900;}
    .tl-dot.blue{background:rgba(0,122,61,0.12);color:var(--vert-dark);}
    .tl-info .lbl{font-size:10.5px;color:var(--gris);font-weight:500;text-transform:uppercase;letter-spacing:0.4px;}
    .tl-info .val{font-size:13px;font-weight:700;}

    /* CTA */
    .btn-cta{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px;border-radius:12px;font-size:13.5px;font-weight:700;font-family:'Poppins',sans-serif;text-decoration:none;transition:all .2s;border:none;cursor:pointer;}
    .btn-cta-primary{background:var(--vert);color:#fff;}
    .btn-cta-primary:hover{background:var(--vert-dark);color:#fff;transform:translateY(-1px);box-shadow:0 6px 18px rgba(0,122,61,0.25);}
    .btn-cta-yellow{background:var(--jaune);color:var(--vert-dark);}
    .btn-cta-yellow:hover{background:#E6BC00;color:var(--vert-dark);transform:translateY(-1px);}

    footer{background:var(--vert-dark);color:rgba(255,255,255,0.75);text-align:center;padding:24px;font-size:12.5px;}
    footer strong{color:var(--jaune);}

    @media(max-width:900px){.main{grid-template-columns:1fr;}}
    @media(max-width:480px){.photos-grid{grid-template-columns:repeat(2,1fr));}}
  </style>
</head>
<body>

  <div class="tricolor-bar">
    <div class="tc-vert"></div>
    <div class="tc-jaune"></div>
    <div class="tc-rouge"></div>
  </div>

  <div class="official-header">
    <div class="container">
      <div class="off-left">
        <div class="fr-name">République du Cameroun</div>
        <div class="motto">Paix - Travail - Patrie</div>
        <div style="height:4px;"></div>
        <div style="font-size:9.5px;color:#4A5568;">Republic of Cameroon</div>
        <div class="motto">Peace - Work - Fatherland</div>
      </div>
      <div class="off-divider"></div>
      <div class="off-center">
        <img src="/assets/images/sceau_cameroun.png" alt="Armoiries">
      </div>
      <div class="off-divider"></div>
      <div class="off-right">
        <div>Portail Citoyen — Détail du Projet</div>
        <div style="font-size:9.5px;color:var(--gris);font-weight:400;margin-top:4px;">Communes Urbaines du Littoral · Cameroun</div>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="nav-inner">
      <a href="<%= siteUrl %>/portail-citoyen" class="nav-brand">
        <img src="/assets/images/logo.png" alt="">
        <span>MuniPro Littoral</span>
      </a>
      <div class="nav-breadcrumb">
        <a href="<%= siteUrl %>/portail-citoyen">Communes</a>
        <span class="sep">›</span>
        <a href="<%= siteUrl %>/portail-citoyen/commune/<%= projet.commune_id %>"><%= projet.commune_nom %></a>
        <span class="sep">›</span>
        <span class="cur"><%= projet.titre.length > 32 ? projet.titre.substring(0,32)+'…' : projet.titre %></span>
      </div>
      <a href="javascript:history.back()" class="btn-retour"><i class="bi bi-arrow-left"></i> Retour</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-type-badge"><i class="bi bi-folder-fill"></i> <%= projet.type_nom || 'Projet Municipal' %></div>
      <h1><%= projet.titre %></h1>
      <div class="hero-location"><i class="bi bi-geo-alt-fill"></i> <%= projet.commune_nom %> — Région du Littoral, Cameroun</div>
    </div>
  </section>

  <!-- STATUS BAR -->
  <div class="status-bar">
    <div class="status-inner">
      <span class="statut-pill sp-<%= projet.statut.replace(' ','_') %>">
        <i class="bi bi-circle-fill" style="font-size:8px;"></i>
        <%= projet.statut.replace('_',' ').toUpperCase() %>
      </span>
      <% if (projet.date_debut) { %>
      <span class="status-meta"><i class="bi bi-calendar-event"></i> Début : <strong><%= new Date(projet.date_debut).toLocaleDateString('fr-FR') %></strong></span>
      <% } %>
      <% if (projet.date_fin_prevue) { %>
      <span class="status-meta"><i class="bi bi-calendar-check"></i> Fin prévue : <strong><%= new Date(projet.date_fin_prevue).toLocaleDateString('fr-FR') %></strong></span>
      <% } %>
      <span class="status-meta"><i class="bi bi-clock-history"></i> Mis à jour le <%= new Date(projet.updated_at || projet.created_at).toLocaleDateString('fr-FR') %></span>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">

    <!-- COLONNE GAUCHE -->
    <div>
      <!-- AVANCEMENT -->
      <div class="card">
        <div class="card-header">
          <i class="bi bi-bar-chart-fill" style="color:var(--vert);"></i>
          <h3>Avancement des travaux</h3>
        </div>
        <div class="progress-section">
          <div class="progress-label">
            <span style="font-size:13.5px;font-weight:600;">Progression physique globale</span>
            <span class="pct" style="color:<%= projet.avancement_physique>70?'var(--vert)':projet.avancement_physique>40?'#F59E0B':'var(--rouge)' %>"><%= projet.avancement_physique %>%</span>
          </div>
          <div class="prog-bar">
            <div class="prog-fill" style="width:<%= projet.avancement_physique %>%;background:<%= projet.avancement_physique>70?'var(--vert)':projet.avancement_physique>40?'#F59E0B':'var(--rouge)' %>;"></div>
          </div>
          <div class="prog-note">
            <% if (projet.avancement_physique >= 100) { %>
            ✅ Projet entièrement réalisé
            <% } else if (projet.avancement_physique >= 70) { %>
            🟢 Avancement satisfaisant — En bonne voie d'achèvement
            <% } else if (projet.avancement_physique >= 40) { %>
            🟡 Avancement modéré — Travaux en cours
            <% } else { %>
            🔴 Avancement faible — Surveillance requise
            <% } %>
          </div>
        </div>
      </div>

      <!-- DESCRIPTION -->
      <% if (projet.description) { %>
      <div class="card">
        <div class="card-header">
          <i class="bi bi-file-text-fill" style="color:var(--vert);"></i>
          <h3>Description du projet</h3>
        </div>
        <div class="card-body">
          <p class="description"><%= projet.description %></p>
        </div>
      </div>
      <% } %>

      <!-- PHOTOS -->
      <% if (photos_list && photos_list.length > 0) { %>
      <div class="card">
        <div class="card-header">
          <i class="bi bi-images" style="color:var(--vert);"></i>
          <h3>Photos du chantier (<%= photos_list.length %>)</h3>
        </div>
        <div class="photos-grid">
          <% photos_list.forEach(ph => { %>
          <div class="photo-item">
            <img src="<%= imageUrl(ph.fichier_url || ph.fichier) %>" alt="Photo du chantier">
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- SIDEBAR DROITE -->
    <div>
      <!-- KPIs -->
      <div class="sidebar-card">
        <h4><i class="bi bi-graph-up"></i> Indicateurs clés</h4>
        <div class="kpi-stack">
          <div class="kpi-row">
            <span class="lbl">Budget du projet</span>
            <span class="val" style="color:var(--vert-dark);"><%= formatMontant(projet.budget_actuel) %></span>
          </div>
          <div class="kpi-row">
            <span class="lbl">Avancement physique</span>
            <span class="val"><%= projet.avancement_physique %>%</span>
          </div>
          <div class="kpi-row">
            <span class="lbl">Secteur</span>
            <span class="val" style="font-size:13px;"><%= projet.type_nom || '—' %></span>
          </div>
          <div class="kpi-row">
            <span class="lbl">Commune</span>
            <span class="val" style="font-size:13px;"><%= projet.commune_nom %></span>
          </div>
        </div>
      </div>

      <!-- CALENDRIER -->
      <div class="sidebar-card">
        <h4><i class="bi bi-calendar3"></i> Calendrier du projet</h4>
        <div class="timeline">
          <% if (projet.date_debut) { %>
          <div class="tl-item">
            <div class="tl-dot green"><i class="bi bi-play-fill"></i></div>
            <div class="tl-info">
              <div class="lbl">Date de début</div>
              <div class="val"><%= new Date(projet.date_debut).toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'}) %></div>
            </div>
          </div>
          <% } %>
          <% if (projet.date_fin_prevue) { %>
          <div class="tl-item">
            <div class="tl-dot yellow"><i class="bi bi-flag-fill"></i></div>
            <div class="tl-info">
              <div class="lbl">Fin prévue</div>
              <div class="val"><%= new Date(projet.date_fin_prevue).toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'}) %></div>
            </div>
          </div>
          <% } %>
          <% if (projet.date_fin_reelle) { %>
          <div class="tl-item">
            <div class="tl-dot blue"><i class="bi bi-check-circle-fill"></i></div>
            <div class="tl-info">
              <div class="lbl">Livraison effective</div>
              <div class="val"><%= new Date(projet.date_fin_reelle).toLocaleDateString('fr-FR', {day:'2-digit',month:'long',year:'numeric'}) %></div>
            </div>
          </div>
          <% } %>
        </div>
      </div>

      <!-- ACTIONS -->
      <div style="display:flex;flex-direction:column;gap:10px;">
        <a href="<%= siteUrl %>/portail-citoyen/suggestion?projet_id=<%= projet.id %>" class="btn-cta btn-cta-yellow">
          <i class="bi bi-chat-dots-fill"></i> Faire une suggestion
        </a>
        <a href="<%= siteUrl %>/portail-citoyen/commune/<%= projet.commune_id %>" class="btn-cta btn-cta-primary">
          <i class="bi bi-building-fill"></i> Tous les projets de la commune
        </a>
      </div>
    </div>

  </div>

  <footer>
    <strong>MuniPro Littoral</strong> — Portail Citoyen · <%= projet.commune_nom %><br>
    <small>© <%= new Date().getFullYear() %> Communes Urbaines du Littoral · République du Cameroun</small>
  </footer>

</body>
</html>
