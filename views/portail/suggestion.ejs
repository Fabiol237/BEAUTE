<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Suggestions & Signalements — MuniPro Portail Citoyen</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <style>
    :root{--green:#007A3D;--yellow:#FCD116;--red:#CE1126;--blue:#003F88;--dark:#0D1B2A;--text:#1A2332;--muted:#64748B;--border:#E2E8F0;--bg:#F0F5FF;--card:#fff;}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

    .topnav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(13,27,42,.97);backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:space-between;padding:0 24px;height:60px;border-bottom:1px solid rgba(255,255,255,.08);}
    .topnav-logo{display:flex;align-items:center;gap:10px;text-decoration:none;}
    .topnav-logo img{height:36px;}
    .topnav-logo span{color:#FCD116;font-weight:800;font-size:16px;}
    .btn-back{display:flex;align-items:center;gap:6px;color:rgba(255,255,255,.6);font-size:11px;font-weight:600;text-decoration:none;border:1px solid rgba(255,255,255,.15);padding:5px 12px;border-radius:20px;transition:all .2s;}
    .btn-back:hover{color:#fff;border-color:rgba(255,255,255,.4);text-decoration:none;}

    .hero{margin-top:60px;background:linear-gradient(135deg,var(--dark),var(--blue));padding:48px 24px;text-align:center;}
    .hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(252,209,22,.15);border:1px solid rgba(252,209,22,.4);color:#FCD116;padding:5px 14px;border-radius:20px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px;}
    .hero h1{color:#fff;font-size:clamp(24px,4vw,36px);font-weight:900;margin-bottom:10px;}
    .hero p{color:rgba(255,255,255,.75);font-size:15px;max-width:540px;margin:0 auto;}

    .main{max-width:820px;margin:0 auto;padding:40px 24px 80px;}

    /* MODE TABS */
    .mode-tabs{display:grid;grid-template-columns:1fr 1fr;gap:0;background:#fff;border-radius:14px;border:1px solid var(--border);overflow:hidden;margin-bottom:28px;box-shadow:0 2px 8px rgba(0,0,0,.05);}
    .mode-tab{padding:16px;text-align:center;text-decoration:none;font-weight:700;font-size:14px;color:var(--muted);border-bottom:3px solid transparent;transition:all .2s;display:flex;align-items:center;justify-content:center;gap:8px;}
    .mode-tab:hover{color:var(--blue);text-decoration:none;}
    .mode-tab.active{color:var(--blue);border-bottom-color:var(--blue);background:#F0F5FF;}

    /* ALERTS */
    .alert{padding:14px 18px;border-radius:12px;margin-bottom:20px;font-size:14px;display:flex;align-items:flex-start;gap:10px;}
    .alert-success{background:rgba(0,122,61,.08);border:1px solid rgba(0,122,61,.2);color:#005A2D;}
    .alert-danger{background:rgba(206,17,38,.08);border:1px solid rgba(206,17,38,.2);color:#9B0E1A;}

    /* FORM CARD */
    .form-card{background:var(--card);border-radius:16px;border:1px solid var(--border);box-shadow:0 2px 8px rgba(0,0,0,.05);overflow:hidden;}
    .form-card-header{padding:20px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;}
    .form-card-header h2{font-size:16px;font-weight:700;margin:0;}
    .form-body{padding:28px;}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
    .form-grid-full{grid-column:1/-1;}
    .form-group{display:flex;flex-direction:column;gap:6px;}
    .form-label{font-size:13px;font-weight:600;color:var(--text);}
    .form-label .req{color:var(--red);}
    .form-control,.form-select{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:10px;font-size:14px;font-family:inherit;color:var(--text);background:#fff;transition:border-color .2s,box-shadow .2s;}
    .form-control:focus,.form-select:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 3px rgba(0,63,136,.1);}
    textarea.form-control{resize:vertical;min-height:120px;}
    .form-hint{font-size:11px;color:var(--muted);}
    .btn-submit{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:14px;background:var(--blue);color:#fff;border:none;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;transition:all .2s;margin-top:8px;}
    .btn-submit:hover{background:#0052B4;transform:translateY(-1px);box-shadow:0 6px 20px rgba(0,63,136,.3);}

    @media(max-width:600px){.form-grid{grid-template-columns:1fr;}}
  </style>
</head>
<body>

<nav class="topnav">
  <a href="<%= siteUrl %>/portail-citoyen" class="topnav-logo">
    <img src="/assets/images/logo.png" alt="MuniPro">
    <span>MuniPro</span>
  </a>
  <a href="<%= siteUrl %>/portail-citoyen" class="btn-back"><i class="bi bi-arrow-left"></i> Retour</a>
</nav>

<div class="hero">
  <div class="hero-badge"><i class="bi bi-chat-quote-fill"></i> Participation citoyenne</div>
  <h1>Suggestions & Signalements</h1>
  <p>Contribuez au développement de votre commune. Chaque retour compte pour améliorer les services municipaux.</p>
</div>

<div class="main">

  <% if (success) { %>
  <div class="alert alert-success">
    <i class="bi bi-check-circle-fill" style="font-size:18px;"></i>
    <div>
      <strong>Merci pour votre contribution !</strong><br>
      Votre <%= mode_success === 'signalement' ? 'signalement' : 'suggestion' %> a bien été reçu(e) et sera traité(e) par la mairie dans les meilleurs délais.
    </div>
  </div>
  <% } %>

  <% if (erreurs && erreurs.length) { %>
  <div class="alert alert-danger">
    <i class="bi bi-exclamation-triangle-fill" style="font-size:18px;"></i>
    <div>
      <strong>Veuillez corriger les erreurs suivantes :</strong>
      <ul style="margin:6px 0 0 16px;">
        <% erreurs.forEach(er => { %><li><%= er %></li><% }); %>
      </ul>
    </div>
  </div>
  <% } %>

  <!-- TABS -->
  <div class="mode-tabs">
    <a href="?mode=suggestion" class="mode-tab <%= mode_actif === 'suggestion' ? 'active' : '' %>">
      <i class="bi bi-lightbulb-fill"></i> Faire une suggestion
    </a>
    <a href="?mode=signalement" class="mode-tab <%= mode_actif === 'signalement' ? 'active' : '' %>">
      <i class="bi bi-exclamation-circle-fill"></i> Signaler un problème
    </a>
  </div>

  <!-- FORM -->
  <div class="form-card">
    <div class="form-card-header">
      <i class="bi bi-<%= mode_actif === 'suggestion' ? 'lightbulb' : 'exclamation-circle' %>" style="color:var(--blue);font-size:18px;"></i>
      <h2><%= mode_actif === 'suggestion' ? 'Nouvelle suggestion citoyenne' : 'Nouveau signalement de problème' %></h2>
    </div>
    <div class="form-body">
      <form method="POST" enctype="multipart/form-data">
        <input type="hidden" name="mode" value="<%= mode_actif %>">
        <div class="form-grid">

          <div class="form-group">
            <label class="form-label">Votre nom <span class="req">*</span></label>
            <input name="nom" class="form-control" value="<%= e(body.nom||'') %>" placeholder="Jean DUPONT" required>
          </div>

          <div class="form-group">
            <label class="form-label">Adresse email <span class="req">*</span></label>
            <input type="email" name="email" class="form-control" value="<%= e(body.email||'') %>" placeholder="jean@exemple.cm" required>
          </div>

          <div class="form-group">
            <label class="form-label">Téléphone</label>
            <input name="telephone" class="form-control" value="<%= e(body.telephone||'') %>" placeholder="+237 6XX XXX XXX">
          </div>

          <div class="form-group">
            <label class="form-label">Projet concerné <span style="color:var(--muted);font-weight:400;">(optionnel)</span></label>
            <select name="projet_id" class="form-select">
              <option value="">— Aucun projet spécifique —</option>
              <% projets.forEach(p => { %><option value="<%= p.id %>" <%= String(body.projet_id)===String(p.id)?'selected':'' %>><%= p.titre %></option><% }); %>
            </select>
          </div>

          <div class="form-group form-grid-full">
            <label class="form-label">Catégorie <span class="req">*</span></label>
            <% if (mode_actif === 'suggestion') { %>
            <select name="categorie" class="form-select" required>
              <option value="">Choisissez une catégorie</option>
              <option value="infrastructure" <%= body.categorie==='infrastructure'?'selected':'' %>>🏗️ Infrastructure & Routes</option>
              <option value="environnement" <%= body.categorie==='environnement'?'selected':'' %>>🌿 Environnement & Déchets</option>
              <option value="sante"          <%= body.categorie==='sante'?'selected':'' %>>🏥 Santé & Hygiène</option>
              <option value="education"      <%= body.categorie==='education'?'selected':'' %>>📚 Éducation & Jeunesse</option>
              <option value="securite"       <%= body.categorie==='securite'?'selected':'' %>>🔒 Sécurité & Ordre public</option>
              <option value="autre"          <%= body.categorie==='autre'?'selected':'' %>>💡 Autre suggestion</option>
            </select>
            <% } else { %>
            <select name="categorie_probleme" class="form-select" required>
              <option value="">Choisissez la nature du problème</option>
              <option value="voirie">🛣️ Voirie & Routes dégradées</option>
              <option value="eclairage">💡 Éclairage public défaillant</option>
              <option value="dechets">🗑️ Collecte des déchets</option>
              <option value="eau">💧 Eau & Assainissement</option>
              <option value="securite">🚨 Problème de sécurité</option>
              <option value="autre">⚠️ Autre problème</option>
            </select>
            <% } %>
          </div>

          <% if (mode_actif === 'signalement') { %>
          <div class="form-group form-grid-full">
            <label class="form-label">Adresse du problème</label>
            <input name="adresse_probleme" class="form-control" value="<%= e(body.adresse_probleme||'') %>" placeholder="Ex: Avenue de la Liberté, quartier Akwa">
          </div>
          <div class="form-group form-grid-full">
            <label class="form-label">Photos du problème <span style="color:var(--muted);font-weight:400;">(max 5 · JPG/PNG/WEBP)</span></label>
            <input type="file" name="photos" class="form-control" accept="image/*" multiple>
          </div>
          <% } %>

          <div class="form-group form-grid-full">
            <label class="form-label">Description détaillée <span class="req">*</span></label>
            <textarea name="message" class="form-control" rows="5" required minlength="20" placeholder="Décrivez votre <%= mode_actif === 'suggestion' ? 'suggestion' : 'signalement' %> avec le maximum de détails possibles (minimum 20 caractères)..."><%= e(body.message||'') %></textarea>
            <span class="form-hint">Minimum 20 caractères requis</span>
          </div>

        </div>
        <button type="submit" class="btn-submit">
          <i class="bi bi-send-fill"></i>
          <%= mode_actif === 'suggestion' ? 'Envoyer ma suggestion' : 'Envoyer le signalement' %>
        </button>
      </form>
    </div>
  </div>

</div>
</body>
</html>
