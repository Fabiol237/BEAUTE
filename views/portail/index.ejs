<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof page_title !== 'undefined' ? page_title : 'Portail Citoyen - Projets Municipaux' %></title>
    
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --vert: #007A3D;
            --vert-dark: #005C2E;
            --jaune: #FCD116;
            --rouge: #CE1126;
            --bg-light: #F0F4F8;
            --text-dark: #1A2332;
            --text-muted: #6C757D;
            --white: #FFFFFF;
        }
        
        * { font-family: 'Poppins', sans-serif; box-sizing: border-box; }
        
        body {
            background-color: var(--bg-light);
            color: var(--text-dark);
            overflow-x: hidden;
        }

        /* ═══════ BANDE TRICOLORE ═══════ */
        .tricolor-bar { display: flex; height: 5px; }
        .tc-vert { flex:1; background: var(--vert); }
        .tc-jaune { flex:1; background: var(--jaune); }
        .tc-rouge { flex:1; background: var(--rouge); }

        /* ═══════ HERO SECTION ═══════ */
        .hero-section {
            background-image: url('<%= globalBanner %>');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            color: white;
            padding: 110px 0 90px;
            position: relative;
            overflow: hidden;
            min-height: 600px;
            display: flex;
            align-items: center;
        }
        
        .hero-section::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg,
                rgba(0, 92, 46, 0.88) 0%,
                rgba(0, 60, 30, 0.80) 40%,
                rgba(206, 17, 38, 0.65) 75%,
                rgba(252, 209, 22, 0.50) 100%
            );
            z-index: 1;
            animation: gradientShift 8s ease-in-out infinite alternate;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; opacity: 0.88; }
            100% { background-position: 100% 50%; opacity: 0.95; }
        }

        /* Floating particles */
        .particles-container {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
            overflow: hidden;
        }
        .particle {
            position: absolute;
            border-radius: 50%;
            opacity: 0;
            animation: floatUp linear infinite;
        }
        @keyframes floatUp {
            0% { transform: translateY(100vh) scale(0); opacity: 0; }
            10% { opacity: 0.6; }
            90% { opacity: 0.3; }
            100% { transform: translateY(-20px) scale(1.2); opacity: 0; }
        }

        /* Pulse ring on hero */
        .hero-pulse-ring {
            position: absolute;
            top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 600px; height: 600px;
            border: 2px solid rgba(252,209,22,0.12);
            border-radius: 50%;
            z-index: 1;
            animation: pulseRing 4s ease-out infinite;
        }
        .hero-pulse-ring:nth-child(2) { width: 900px; height: 900px; animation-delay: 1.5s; }
        .hero-pulse-ring:nth-child(3) { width: 1200px; height: 1200px; animation-delay: 3s; }
        @keyframes pulseRing {
            0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
            100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
        }
        
        .hero-content {
            position: relative;
            z-index: 2;
            width: 100%;
        }
        
        .hero-title {
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 900;
            margin-bottom: 1rem;
            text-shadow: 0 4px 20px rgba(0,0,0,0.3);
            animation: slideInDown 0.8s ease-out;
            line-height: 1.15;
        }
        
        .hero-subtitle {
            font-size: 1.2rem;
            font-weight: 400;
            opacity: 0.92;
            animation: slideInUp 0.8s ease-out 0.2s both;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(252,209,22,0.18);
            border: 1px solid rgba(252,209,22,0.5);
            color: var(--jaune);
            padding: 7px 18px;
            border-radius: 30px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 20px;
            animation: fadeIn 0.6s ease-out;
        }
        .hero-badge .dot { width: 6px; height: 6px; background: var(--jaune); border-radius: 50%; animation: blink 1.5s ease-in-out infinite; }
        @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:0.2;} }

        @keyframes slideInDown {
            from { opacity: 0; transform: translateY(-30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes slideInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 0.92; transform: translateY(0); }
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* ═══════ ACTION BUTTONS ═══════ */
        .btn-hero-primary {
            background: linear-gradient(135deg, var(--vert), #009F50);
            color: white;
            padding: 13px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 6px 20px rgba(0,122,61,0.4);
            border: none;
        }
        .btn-hero-primary:hover {
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 35px rgba(0,122,61,0.5);
            color: white;
        }

        .btn-hero-yellow {
            background: linear-gradient(135deg, #FCD116, #E6A800);
            color: #1A2332;
            padding: 13px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 800;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 6px 25px rgba(252,209,22,0.5);
        }
        .btn-hero-yellow:hover {
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 12px 40px rgba(252,209,22,0.7);
            color: #1A2332;
        }

        .btn-hero-glass {
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(10px);
            color: white;
            padding: 13px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            border: 2px solid rgba(255,255,255,0.4);
            transition: all 0.3s ease;
        }
        .btn-hero-glass:hover {
            background: rgba(255,255,255,0.25);
            transform: translateY(-2px);
            color: white;
        }
        
        /* ═══════ STATS SECTION ═══════ */
        .stats-section {
            margin-top: -50px;
            position: relative;
            z-index: 10;
        }
        
        .stat-card {
            background: white;
            border-radius: 18px;
            padding: 28px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.09);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
            border-left: 5px solid var(--vert);
            position: relative;
            overflow: hidden;
        }
        .stat-card::after {
            content: '';
            position: absolute;
            top: -50%;
            right: -20px;
            width: 80px;
            height: 160%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), transparent);
            transform: skewX(-15deg);
            transition: right 0.6s ease;
            opacity: 0;
        }
        .stat-card:hover::after { right: 120%; opacity: 1; }
        
        .stat-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 20px 50px rgba(0,0,0,0.14);
        }
        
        .stat-card.jaune { border-left-color: var(--jaune); }
        .stat-card.rouge { border-left-color: var(--rouge); }
        
        .stat-card .stat-icon {
            width: 64px; height: 64px;
            border-radius: 16px;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; margin-bottom: 16px;
            transition: transform 0.3s ease;
        }
        .stat-card:hover .stat-icon { transform: rotate(10deg) scale(1.1); }
        .stat-card.vert .stat-icon { background: rgba(0,122,61,0.10); color: var(--vert); }
        .stat-card.jaune .stat-icon { background: rgba(252,209,22,0.15); color: #C49B00; }
        .stat-card.rouge .stat-icon { background: rgba(206,17,38,0.10); color: var(--rouge); }
        
        .stat-card .stat-value {
            font-size: 2.4rem; font-weight: 900;
            color: var(--text-dark);
            line-height: 1;
            background: linear-gradient(135deg, var(--text-dark), var(--vert-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .stat-card.jaune .stat-value { background: linear-gradient(135deg, var(--text-dark), #C49B00); -webkit-background-clip: text; background-clip: text; }
        .stat-card.rouge .stat-value { background: linear-gradient(135deg, var(--text-dark), var(--rouge)); -webkit-background-clip: text; background-clip: text; }
        
        .stat-card .stat-label { color: var(--text-muted); font-size: 0.9rem; margin-top: 6px; font-weight: 500; }

        /* ═══════ SCROLL REVEAL ═══════ */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: opacity 0.7s ease, transform 0.7s ease;
        }
        .reveal.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .reveal-delay-1 { transition-delay: 0.1s; }
        .reveal-delay-2 { transition-delay: 0.2s; }
        .reveal-delay-3 { transition-delay: 0.3s; }
        .reveal-delay-4 { transition-delay: 0.4s; }

        /* ═══════ SECTION DIVIDER ═══════ */
        .section-divider {
            text-align: center;
            padding: 16px 0 8px;
            position: relative;
        }
        .section-divider::before {
            content: '';
            position: absolute;
            top: 50%; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(0,122,61,0.3), transparent);
        }
        .section-divider span {
            background: var(--bg-light);
            padding: 0 16px;
            font-size: 24px;
            position: relative;
            z-index: 1;
        }

        /* ═══════ PROJECT CARDS ═══════ */
        .project-card {
            background: white;
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 4px 16px rgba(0,0,0,0.07);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
            border: 1px solid rgba(0,0,0,0.05);
        }
        .project-card:hover {
            box-shadow: 0 16px 50px rgba(0,0,0,0.14);
            transform: translateY(-8px);
        }
        
        .project-card-image {
            height: 210px;
            background: linear-gradient(135deg, var(--vert), #FCD116);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 3rem;
            position: relative;
            overflow: hidden;
        }
        .project-card-image img {
            width: 100%; height: 100%; object-fit: cover;
            transition: transform 0.5s ease;
        }
        .project-card:hover .project-card-image img { transform: scale(1.08); }
        
        .project-card-image.has-photo {
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }
        .project-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.1), rgba(0,0,0,0.55));
        }
        .project-card-image .project-icon {
            position: relative; z-index: 1;
            display: flex; align-items: center; justify-content: center;
            height: 100%; color: white; font-size: 3rem;
        }
        .project-card-body { padding: 22px; }
        .project-title {
            font-size: 1.05rem; font-weight: 700; margin-bottom: 10px;
            color: var(--text-dark);
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            line-height: 1.4;
        }
        .project-meta {
            display: flex; gap: 12px; margin-bottom: 14px;
            font-size: 0.82rem; color: var(--text-muted);
        }
        .progress-section { margin-bottom: 16px; }
        .progress { height: 8px; border-radius: 10px; background: #E9ECEF; overflow: hidden; }
        .progress-bar {
            background: linear-gradient(90deg, var(--vert), var(--jaune));
            border-radius: 10px;
            transition: width 1.5s ease;
        }
        .badge-custom { padding: 5px 14px; border-radius: 20px; font-weight: 600; font-size: 0.78rem; }
        .badge-en-cours { background: rgba(0,122,61,0.1); color: var(--vert); }
        .badge-termine { background: rgba(14,165,233,0.1); color: #0EA5E9; }

        /* ═══════ BUTTONS ═══════ */
        .btn-cameroun {
            background: linear-gradient(135deg, var(--vert), #009F50);
            color: white; border: none;
            padding: 10px 24px; border-radius: 10px;
            font-weight: 600; transition: all 0.3s ease;
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 13px;
        }
        .btn-cameroun:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,122,61,0.35);
            color: white;
        }
        .btn-outline-cameroun {
            border: 2px solid var(--vert); color: var(--vert);
            background: transparent; padding: 10px 24px;
            border-radius: 10px; font-weight: 600;
            transition: all 0.3s ease;
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 13px;
        }
        .btn-outline-cameroun:hover {
            background: var(--vert); color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,122,61,0.25);
        }
        
        /* ═══════ SECTION TITLES ═══════ */
        .section-title {
            font-size: 1.9rem; font-weight: 800;
            color: var(--text-dark); margin-bottom: 8px;
            position: relative; display: inline-block;
        }
        .section-title::after {
            content: '';
            position: absolute; bottom: -6px; left: 0;
            width: 50px; height: 4px;
            background: linear-gradient(90deg, var(--vert), var(--jaune));
            border-radius: 2px;
            animation: expandBar 0.8s ease forwards;
        }
        @keyframes expandBar {
            from { width: 0; }
            to { width: 50px; }
        }

        /* ═══════ CTA SECTION ═══════ */
        .cta-section {
            background: linear-gradient(135deg, var(--vert-dark), #003825);
            border-radius: 24px;
            padding: 56px;
            text-align: center;
            color: white;
            position: relative;
            overflow: hidden;
        }
        .cta-section::before {
            content: '';
            position: absolute; inset: 0;
            background: radial-gradient(circle at 30% 50%, rgba(252,209,22,0.12) 0%, transparent 60%),
                        radial-gradient(circle at 70% 50%, rgba(0,122,61,0.15) 0%, transparent 60%);
        }
        .cta-content { position: relative; z-index: 1; }

        /* ═══════ LIVE TICKER ═══════ */
        .live-ticker {
            background: linear-gradient(135deg, var(--vert-dark), #003220);
            color: white;
            padding: 10px 0;
            overflow: hidden;
            position: relative;
        }
        .ticker-track {
            display: flex;
            animation: ticker 30s linear infinite;
            white-space: nowrap;
        }
        .ticker-item {
            padding: 0 32px;
            font-size: 12px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            opacity: 0.9;
        }
        .ticker-dot { width: 6px; height: 6px; background: var(--jaune); border-radius: 50%; flex-shrink: 0; }
        @keyframes ticker {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* ═══════ FOOTER ═══════ */
        .footer {
            background: #0D1F14;
            color: rgba(255,255,255,0.8);
            padding: 50px 0 24px;
            margin-top: 80px;
        }
        .footer a { color: var(--jaune); text-decoration: none; transition: color 0.2s; }
        .footer a:hover { color: #fff; }
        .footer-brand { font-size: 1.1rem; font-weight: 800; color: white; }

        @media(max-width:768px){
            .hero-section { padding: 80px 0 60px; min-height: 500px; background-attachment: scroll; }
            .stats-section { margin-top: -20px; }
            .cta-section { padding: 36px 24px; }
        }
    </style>
</head>
<body>
    <!-- Bande tricolore -->
    <div class="tricolor-bar"><div class="tc-vert"></div><div class="tc-jaune"></div><div class="tc-rouge"></div></div>

    <!-- Navbar partagée avec bouton langue -->
    <%- include('./_navbar') %>

    <!-- ═══ LIVE TICKER ═══ -->
    <div class="live-ticker">
      <div class="ticker-track" id="tickerTrack">
        <% if(projets_recents && projets_recents.length > 0) { projets_recents.concat(projets_recents).forEach(p => { %>
          <span class="ticker-item"><span class="ticker-dot"></span> <%= e(p.titre) %> — <%= p.avancement_physique %>% avancement</span>
        <% }); } else { %>
          <span class="ticker-item"><span class="ticker-dot"></span> Bienvenue sur le Portail Citoyen des Communes du Littoral 🇨🇲</span>
          <span class="ticker-item"><span class="ticker-dot"></span> Plateforme officielle de suivi des projets municipaux</span>
          <span class="ticker-item"><span class="ticker-dot"></span> Transparence · Proximité · Participation citoyenne</span>
          <span class="ticker-item"><span class="ticker-dot"></span> Bienvenue sur le Portail Citoyen des Communes du Littoral 🇨🇲</span>
          <span class="ticker-item"><span class="ticker-dot"></span> Plateforme officielle de suivi des projets municipaux</span>
          <span class="ticker-item"><span class="ticker-dot"></span> Transparence · Proximité · Participation citoyenne</span>
        <% } %>
      </div>
    </div>

    <!-- Hero Section -->
    <section class="hero-section">
        <!-- Pulse rings -->
        <div class="hero-pulse-ring"></div>
        <div class="hero-pulse-ring"></div>
        <div class="hero-pulse-ring"></div>

        <!-- Particles -->
        <div class="particles-container" id="particlesContainer"></div>

        <div class="container hero-content">
            <div class="text-center">
                <div class="hero-badge">
                  <span class="dot"></span>
                  🇨🇲 Portail Officiel · Communes Urbaines du Littoral
                </div>
                <h1 class="hero-title">
                    Projets Municipaux<br>
                    <span style="color: var(--jaune); font-size: 0.65em; font-weight: 600;">Communes Urbaines du Littoral — Cameroun</span>
                </h1>
                <p class="hero-subtitle">
                    Suivez en temps réel les projets de développement de votre commune.<br>
                    Transparence, proximité et participation citoyenne.
                </p>
                
                <!-- Actions rapides -->
                <div style="display:flex;gap:14px;justify-content:center;margin-top:36px;flex-wrap:wrap;">
                  <a href="<%= siteUrl %>/portail-citoyen/projets" class="btn-hero-primary">
                    <i class="bi bi-folder-fill"></i> Voir tous les projets
                  </a>
                  <a href="javascript:void(0)" onclick="VisualSearch.open()" class="btn-hero-yellow">
                    <i class="bi bi-camera-fill"></i> Recherche Visuelle IA
                  </a>
                  <a href="<%= siteUrl %>/portail-citoyen/carte" class="btn-hero-glass">
                    <i class="bi bi-globe2"></i> Carte Satellitaire
                  </a>
                </div>

                <!-- Scroll indicator -->
                <div style="margin-top: 48px; animation: bounceDown 2s ease-in-out infinite;">
                  <i class="bi bi-chevron-double-down" style="font-size: 1.5rem; opacity: 0.7; color: var(--jaune);"></i>
                </div>
            </div>
        </div>
    </section>
    <style>
      @keyframes bounceDown {
        0%,100% { transform: translateY(0); }
        50% { transform: translateY(8px); }
      }
    </style>
    
    <!-- Stats Section -->
    <section class="stats-section">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-3 reveal reveal-delay-1">
                    <div class="stat-card vert">
                        <div class="stat-icon"><i class="bi bi-folder-fill"></i></div>
                        <div class="stat-value" data-target="<%= stats.total || 0 %>">0</div>
                        <div class="stat-label">🏗️ Projets totaux</div>
                    </div>
                </div>
                <div class="col-md-3 reveal reveal-delay-2">
                    <div class="stat-card jaune">
                        <div class="stat-icon"><i class="bi bi-hammer"></i></div>
                        <div class="stat-value" data-target="<%= stats.en_cours || 0 %>">0</div>
                        <div class="stat-label">⚡ En cours</div>
                    </div>
                </div>
                <div class="col-md-3 reveal reveal-delay-3">
                    <div class="stat-card rouge">
                        <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
                        <div class="stat-value" data-target="<%= stats.termines || 0 %>">0</div>
                        <div class="stat-label">✅ Terminés</div>
                    </div>
                </div>
                <div class="col-md-3 reveal reveal-delay-4">
                    <div class="stat-card vert">
                        <div class="stat-icon"><i class="bi bi-cash-coin"></i></div>
                        <div class="stat-value" data-target="<%= Math.round((stats.budget_total || 0) / 1000000) %>" data-suffix="M">0</div>
                        <div class="stat-label">💰 Budget total (FCFA)</div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- Divider -->
    <div class="section-divider mt-4"><span>🇨🇲</span></div>

    <!-- Projets Récents -->
    <section class="container mt-4 pt-3">
        <div class="d-flex justify-content-between align-items-center mb-4 reveal">
            <div>
                <h2 class="section-title">Projets Récents</h2>
                <p class="text-muted mt-3">Découvrez les derniers projets lancés dans votre région</p>
            </div>
            <a href="<%= siteUrl %>/portail-citoyen/projets" class="btn-outline-cameroun">
                Voir tous les projets
                <i class="bi bi-arrow-right ms-2"></i>
            </a>
        </div>
        
        <div class="row g-4">
