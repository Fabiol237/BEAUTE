<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Carte Satellitaire — Portail Citoyen</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Poppins', sans-serif; }
    body { margin: 0; background: #0a0a1a; color: white; }
    .hero-nav {
      background: linear-gradient(135deg, rgba(0,122,61,0.95), rgba(0,63,136,0.95));
      backdrop-filter: blur(10px);
      padding: 14px 24px;
      display: flex; align-items: center; justify-content: space-between;
      position: sticky; top: 0; z-index: 1000;
      box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }
    .hero-nav .brand { font-size: 18px; font-weight: 800; color: white; text-decoration: none; display: flex; align-items: center; gap: 10px; }
    .hero-nav .nav-links { display: flex; gap: 20px; }
    .hero-nav .nav-links a { color: rgba(255,255,255,0.85); text-decoration: none; font-size: 14px; font-weight: 500; transition: color .2s; }
    .hero-nav .nav-links a:hover { color: #FCD116; }
    #map { width: 100%; height: calc(100vh - 60px); }
    .map-overlay {
      position: absolute;
      top: 70px; left: 16px; z-index: 500;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      padding: 16px;
      color: white;
      min-width: 240px;
      max-width: 280px;
    }
    .overlay-title { font-size: 14px; font-weight: 700; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .stat-row { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid rgba(255,255,255,0.08); font-size: 13px; }
    .stat-row:last-child { border: none; }
    .stat-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
    .filter-section { margin-top: 14px; }
    .filter-section label { font-size: 11px; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 0.5px; display: block; margin-bottom: 6px; }
    .filter-select { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; color: white; padding: 7px 10px; font-size: 13px; width: 100%; }
    .filter-select option { background: #1e293b; color: white; }
    .layer-row { display: flex; gap: 6px; margin-top: 10px; }
    .layer-pill { flex: 1; padding: 6px 4px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.2); background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7); font-size: 11px; font-weight: 600; cursor: pointer; text-align: center; transition: all .2s; }
    .layer-pill.active { background: #007A3D; border-color: #007A3D; color: white; }
    .leaflet-popup-content-wrapper { border-radius: 14px; box-shadow: 0 12px 40px rgba(0,0,0,0.4); border: none; overflow: hidden; }
    .leaflet-popup-content { margin: 0; padding: 0; min-width: 240px; }
    .popup-inner { padding: 14px 16px; }
    .popup-title { font-size: 14px; font-weight: 700; color: #1e293b; margin-bottom: 6px; line-height: 1.3; }
    .popup-badge { display: inline-block; padding: 2px 10px; border-radius: 10px; font-size: 11px; font-weight: 700; margin-bottom: 8px; }
    .popup-bar { height: 6px; background: #e2e8f0; border-radius: 4px; margin-bottom: 8px; overflow: hidden; }
    .popup-bar-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #007A3D, #FCD116); }
    .popup-link { display: block; text-align: center; background: #007A3D; color: white !important; padding: 9px; border-radius: 8px; font-size: 12px; font-weight: 700; text-decoration: none !important; margin-top: 10px; }
    .popup-link:hover { background: #005a2c; }
  </style>
</head>
<body>
  <nav class="hero-nav">
    <a href="<%= siteUrl %>/portail-citoyen" class="brand">
      <img src="/assets/images/logo.png" style="height:32px;width:32px;object-fit:contain;background:white;padding:4px;border-radius:8px;" alt="Logo">
      Portail Citoyen
    </a>
    <div class="nav-links">
      <a href="<%= siteUrl %>/portail-citoyen/projets"><i class="bi bi-folder me-1"></i>Projets</a>
      <a href="<%= siteUrl %>/portail-citoyen/suggestion"><i class="bi bi-chat-dots me-1"></i>Suggestion</a>
    </div>
  </nav>

  <!-- Overlay stats + filtres -->
  <div class="map-overlay" id="mapOverlay">
    <div class="overlay-title">🗺️ Projets Municipaux</div>
    <div class="stat-row"><span style="display:flex;align-items:center;gap:6px;"><span class="stat-dot" style="background:#2563eb;"></span>En cours</span><strong id="cnt-encours">0</strong></div>
    <div class="stat-row"><span style="display:flex;align-items:center;gap:6px;"><span class="stat-dot" style="background:#10b981;"></span>Terminés</span><strong id="cnt-termines">0</strong></div>
    <div class="stat-row"><span style="display:flex;align-items:center;gap:6px;"><span class="stat-dot" style="background:#64748b;"></span>Planifiés</span><strong id="cnt-planifies">0</strong></div>
    <div class="stat-row"><span style="display:flex;align-items:center;gap:6px;"><span class="stat-dot" style="background:#f59e0b;"></span>Suspendus</span><strong id="cnt-suspendus">0</strong></div>

    <div class="filter-section">
      <label>Filtrer par statut</label>
      <select class="filter-select" id="statutFilter">
        <option value="">Tous les projets</option>
        <option value="en_cours">🔨 En cours</option>
        <option value="terminé">✅ Terminés</option>
        <option value="planifié">📋 Planifiés</option>
        <option value="suspendu">⏸️ Suspendus</option>
      </select>
    </div>

    <div class="filter-section">
      <label>Fond de carte</label>
      <div class="layer-row">
        <div class="layer-pill active" onclick="setLayer('satellite',this)">🛰️ Satellite</div>
        <div class="layer-pill" onclick="setLayer('street',this)">🏙️ Rue</div>
        <div class="layer-pill" onclick="setLayer('topo',this)">🗻 Topo</div>
      </div>
    </div>
  </div>

  <div id="map"></div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
  <script>
    const projetsData = <%- JSON.stringify(projets) %>;
    const siteUrl = '<%= siteUrl %>';

    const tileLayers = {
      satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri', maxZoom: 19 }),
      street: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OSM', maxZoom: 19 }),
      topo: L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png', { attribution: '© OpenTopoMap', maxZoom: 17 })
    };

    const map = L.map('map', { zoomControl: true }).setView([4.0511, 9.7679], 11);
    tileLayers.satellite.addTo(map);

    const statusColors = { 'en_cours': '#2563eb', 'planifié': '#64748b', 'terminé': '#10b981', 'suspendu': '#f59e0b' };
    const statusEmoji = { 'en_cours': '🔨', 'planifié': '📋', 'terminé': '✅', 'suspendu': '⏸️' };

    function makeIcon(color) {
      return L.divIcon({
        className: '',
        html: `<div style="width:34px;height:34px;border-radius:50%;background:${color};border:3px solid white;box-shadow:0 4px 16px rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;"><div style="width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,0.9);"></div></div>`,
        iconSize: [34, 34], iconAnchor: [17, 17], popupAnchor: [0, -20]
      });
    }

    const cluster = L.markerClusterGroup({ maxClusterRadius: 60, showCoverageOnHover: false });

    function updateStats(list) {
      document.getElementById('cnt-encours').textContent = list.filter(p => p.statut === 'en_cours').length;
      document.getElementById('cnt-termines').textContent = list.filter(p => p.statut === 'terminé').length;
      document.getElementById('cnt-planifies').textContent = list.filter(p => p.statut === 'planifié').length;
      document.getElementById('cnt-suspendus').textContent = list.filter(p => p.statut === 'suspendu').length;
    }

    function addMarkers(list) {
      cluster.clearLayers();
      list.forEach(p => {
        if (!p.latitude || !p.longitude) return;
        const color = statusColors[p.statut] || '#64748b';
        const emoji = statusEmoji[p.statut] || '📍';
        const budget = p.budget_actuel ? Math.round(Number(p.budget_actuel) / 1000000) + 'M FCFA' : '—';
        const photoHtml = p.photo ? `<img src="/uploads/${p.photo}" style="width:100%;height:120px;object-fit:cover;border-radius:8px;margin-bottom:8px;" onerror="this.style.display='none'">` : '';
        const popup = `<div class="popup-inner">
          ${photoHtml}
          <div class="popup-title">${p.titre}</div>
          <span class="popup-badge" style="background:${color}18;color:${color};">${emoji} ${p.statut}</span>
          <div style="font-size:11px;color:#64748b;margin-bottom:8px;">💰 ${budget}</div>
          <div class="popup-bar"><div class="popup-bar-fill" style="width:${p.avancement_physique || 0}%"></div></div>
          <small style="color:#64748b;">${p.avancement_physique || 0}% réalisé</small>
          <a href="${siteUrl}/portail-citoyen/projet/${p.id}" class="popup-link">Voir le projet →</a>
        </div>`;
        cluster.addLayer(L.marker([p.latitude, p.longitude], { icon: makeIcon(color) }).bindPopup(popup, { maxWidth: 260 }));
      });
      map.addLayer(cluster);
      if (cluster.getLayers().length) { try { map.fitBounds(cluster.getBounds().pad(0.15)); } catch (e) {} }
    }

    updateStats(projetsData);
    addMarkers(projetsData);

    document.getElementById('statutFilter').onchange = function () {
      const s = this.value;
      const filtered = s ? projetsData.filter(p => p.statut === s) : projetsData;
      addMarkers(filtered);
      updateStats(filtered);
    };

    function setLayer(name, el) {
      Object.values(tileLayers).forEach(l => map.removeLayer(l));
      tileLayers[name].addTo(map);
      document.querySelectorAll('.layer-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
    }
  </script>
</body>
</html>
