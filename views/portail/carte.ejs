<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Carte satellitaire des projets municipaux — Portail Citoyen des Communes du Littoral, République du Cameroun">
  <title>Carte des Projets — Portail Citoyen · République du Cameroun</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>
  <style>
    :root {
      --vert: #007A3D; --vert-dark: #005C2E; --vert-light: #E8F5EE;
      --jaune: #FCD116; --rouge: #CE1126;
      --noir: #1A1A1A; --gris: #6C757D; --gris-clair: #F4F6F8;
      --blanc: #FFFFFF; --border: #DDE3EA;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; font-family: 'Poppins', sans-serif; background: var(--noir); color: var(--blanc); }

    .tricolor-bar { display: flex; height: 5px; }
    .tc-vert{flex:1;background:var(--vert);} .tc-jaune{flex:1;background:var(--jaune);} .tc-rouge{flex:1;background:var(--rouge);}

    /* HEADER OFFICIEL COMPACT */
    .official-header {
      background: var(--blanc); border-bottom: 3px solid var(--vert); padding: 10px 28px;
    }
    .official-header .container { max-width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
    .off-left { font-size: 9.5px; font-weight: 600; color: #2C3E50; text-transform: uppercase; }
    .off-left .fr-name { font-size: 11px; font-weight: 800; color: var(--vert-dark); }
    .off-left .motto { font-style: italic; color: var(--gris); font-weight: 400; text-transform: none; }
    .off-center img { height: 52px; filter: drop-shadow(0 1px 4px rgba(0,0,0,0.1)); }
    .off-divider { width: 1px; height: 44px; background: var(--border); }
    .off-right { font-size: 9.5px; text-align: right; color: #2C3E50; font-weight: 600; }
    @media(max-width:768px){.off-left,.off-right,.off-divider{display:none;}.official-header .container{justify-content:center;}}

    /* NAVBAR */
    .main-nav {
      background: var(--vert-dark); padding: 0 24px;
      box-shadow: 0 3px 12px rgba(0,0,0,0.25);
    }
    .nav-inner { max-width: 100%; display: flex; align-items: center; justify-content: space-between; height: 50px; }
    .nav-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
    .nav-brand img { height: 28px; }
    .nav-brand span { color: var(--jaune); font-weight: 800; font-size: 14px; }
    .nav-controls { display: flex; align-items: center; gap: 8px; }
    .nav-pill {
      padding: 5px 14px; border-radius: 20px; font-size: 11.5px; font-weight: 600; cursor: pointer;
      transition: all .2s; border: 1px solid rgba(255,255,255,0.2); color: rgba(255,255,255,0.8);
      text-decoration: none; display: flex; align-items: center; gap: 5px; background: transparent;
      font-family: 'Poppins', sans-serif;
    }
    .nav-pill:hover, .nav-pill.active { background: rgba(255,255,255,0.15); color: var(--jaune); border-color: rgba(255,255,255,0.4); }
    .nav-pill.layer-pill.active { background: var(--jaune); color: var(--vert-dark); border-color: var(--jaune); }
    .select-filter { padding: 5px 12px; background: rgba(255,255,255,0.1); color: #fff; border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; font-size: 11.5px; font-family: 'Poppins', sans-serif; cursor: pointer; }
    .select-filter option { background: var(--vert-dark); color: #fff; }
    .btn-retour-nav { display: flex; align-items: center; gap: 5px; color: rgba(255,255,255,0.7); font-size: 11.5px; font-weight: 600; text-decoration: none; border: 1px solid rgba(255,255,255,0.2); padding: 5px 12px; border-radius: 20px; transition: all .2s; }
    .btn-retour-nav:hover { color: #fff; border-color: rgba(255,255,255,0.5); }

    /* MAP */
    #map-container { position: relative; display: flex; flex-direction: column; height: calc(100vh - 135px); }
    #map { flex: 1; width: 100%; z-index: 1; }

    /* STATS PANEL */
    .stats-panel {
      position: absolute; bottom: 20px; left: 20px; z-index: 1000;
      background: rgba(0,92,46,0.92); backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.2); border-radius: 16px;
      padding: 18px 22px; min-width: 240px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }
    .stats-panel h4 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--jaune); margin-bottom: 14px; display: flex; align-items: center; gap: 6px; }
    .stat-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    .stat-row:last-child { margin-bottom: 0; }
    .stat-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 6px; }
    .stat-label { font-size: 12px; color: rgba(255,255,255,0.8); }
    .stat-val { font-size: 13px; font-weight: 800; color: #fff; }

    /* LEGEND POPUP */
    .legend-panel {
      position: absolute; top: 16px; right: 16px; z-index: 1000;
      background: rgba(0,40,20,0.92); backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15); border-radius: 14px;
      padding: 14px 18px; min-width: 180px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }
    .legend-panel h5 { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--jaune); margin-bottom: 10px; }
    .legend-item { display: flex; align-items: center; gap: 8px; margin-bottom: 7px; font-size: 11.5px; color: rgba(255,255,255,0.85); }
    .legend-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }

    .popup-inner { font-family: 'Poppins', sans-serif; min-width: 220px; }
    .popup-title { font-weight: 800; font-size: 13px; margin-bottom: 6px; color: #1A1A1A; }
    .popup-badge { display: inline-block; padding: 2px 8px; border-radius: 12px; font-size: 10px; font-weight: 700; margin-bottom: 8px; }
    .popup-bar { height: 6px; background: #E2E8F0; border-radius: 4px; margin-bottom: 4px; }
    .popup-bar-fill { height: 100%; border-radius: 4px; }
    .popup-link { display: block; margin-top: 10px; background: var(--vert); color: #fff; text-align: center; padding: 7px; border-radius: 8px; text-decoration: none; font-size: 12px; font-weight: 700; }
    .popup-link:hover { background: var(--vert-dark); }

    @media(max-width:768px){
      #map-container { height: auto; min-height: calc(100vh - 100px); }
      #map { height: 55vh; flex: none; }
      .stats-panel { position: static; width: 100%; border-radius: 0; box-shadow: none; border-left: none; border-right: none; }
      .legend-panel { display: none; }
    }
  </style>
</head>
<body>

  <div class="tricolor-bar">
    <div class="tc-vert"></div>
    <div class="tc-jaune"></div>
    <div class="tc-rouge"></div>
  </div>

  <div class="official-header">
    <div class="container">
      <div class="off-left">
        <div class="fr-name">République du Cameroun</div>
        <div class="motto">Paix - Travail - Patrie</div>
        <div style="height:3px;"></div>
        <div style="font-size:9px;color:#4A5568;">Republic of Cameroon · Peace - Work - Fatherland</div>
      </div>
      <div class="off-divider"></div>
      <div class="off-center">
        <img src="/assets/images/sceau_cameroun.png" alt="Armoiries">
      </div>
      <div class="off-divider"></div>
      <div class="off-right">
        <div style="font-size:11px;font-weight:800;color:var(--vert-dark);">Carte Satellitaire des Projets</div>
        <div style="font-size:9px;color:var(--gris);font-weight:400;margin-top:3px;">Communes Urbaines du Littoral · Cameroun</div>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="nav-inner">
      <a href="<%= siteUrl %>/portail-citoyen" class="nav-brand">
        <img src="/assets/images/logo.png" alt="">
        <span>MuniPro Littoral</span>
      </a>
      <div class="nav-controls">
        <select id="statutFilter" class="select-filter">
          <option value="">Tous les statuts</option>
          <option value="en_cours">En cours</option>
          <option value="terminé">Terminés</option>
          <option value="planifié">Planifiés</option>
          <option value="suspendu">Suspendus</option>
        </select>
        <button class="nav-pill layer-pill active" onclick="setLayer('osm',this)"><i class="bi bi-map"></i> Standard</button>
        <button class="nav-pill layer-pill" onclick="setLayer('satellite',this)"><i class="bi bi-globe2"></i> Satellite</button>
        <a href="<%= siteUrl %>/portail-citoyen" class="btn-retour-nav"><i class="bi bi-arrow-left"></i> Portail</a>
        <% const _cl = typeof currentLang !== 'undefined' ? currentLang : 'fr'; %>
        <a href="?lang=<%= _cl === 'fr' ? 'en' : 'fr' %>" style="display:inline-flex;align-items:center;gap:5px;background:rgba(252,209,22,0.18);border:1.5px solid rgba(252,209,22,0.5);color:#FCD116;font-weight:700;font-size:12px;padding:4px 12px;border-radius:20px;text-decoration:none;transition:all .2s;" onmouseover="this.style.background='#FCD116';this.style.color='#003A1C';" onmouseout="this.style.background='rgba(252,209,22,0.18)';this.style.color='#FCD116';">
          <%= _cl === 'fr' ? '🇬🇧 EN' : '🇫🇷 FR' %>
        </a>
      </div>
    </div>
  </nav>

  <div id="map-container">
    <div id="map"></div>

    <!-- STATS PANEL -->
    <div class="stats-panel">
      <h4><i class="bi bi-pin-map-fill"></i> Statistiques</h4>
      <div class="stat-row">
        <span class="stat-label"><span class="stat-dot" style="background:#007A3D;"></span>En cours</span>
        <span class="stat-val" id="stat-en-cours">0</span>
      </div>
      <div class="stat-row">
        <span class="stat-label"><span class="stat-dot" style="background:#0EA5E9;"></span>Terminés</span>
        <span class="stat-val" id="stat-termines">0</span>
      </div>
      <div class="stat-row">
        <span class="stat-label"><span class="stat-dot" style="background:#F59E0B;"></span>Planifiés</span>
        <span class="stat-val" id="stat-planifies">0</span>
      </div>
      <div class="stat-row">
        <span class="stat-label"><span class="stat-dot" style="background:#EF4444;"></span>Suspendus</span>
        <span class="stat-val" id="stat-suspendus">0</span>
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.2);margin-top:10px;padding-top:10px;">
        <div class="stat-row">
          <span class="stat-label" style="color:var(--jaune);font-weight:700;">Total affiché</span>
          <span class="stat-val" id="stat-total" style="color:var(--jaune);">0</span>
        </div>
      </div>
    </div>

    <!-- LÉGENDE -->
    <div class="legend-panel">
      <h5><i class="bi bi-info-circle"></i> Légende</h5>
      <div class="legend-item"><span class="legend-dot" style="background:#007A3D;"></span> En cours</div>
      <div class="legend-item"><span class="legend-dot" style="background:#0EA5E9;"></span> Terminé</div>
      <div class="legend-item"><span class="legend-dot" style="background:#F59E0B;"></span> Planifié</div>
      <div class="legend-item"><span class="legend-dot" style="background:#FCD116;"></span> Suspendu</div>
      <div class="legend-item"><span class="legend-dot" style="background:#CE1126;"></span> Annulé</div>
    </div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
  <script>
    const siteUrl = '<%= siteUrl %>';
    const projetsData = <%- JSON.stringify(projets) %>;
    const statusColors = {
      'en_cours': '#007A3D',
      'terminé': '#0EA5E9',
      'planifié': '#F59E0B',
      'suspendu': '#FCD116',
      'annulé': '#CE1126'
    };

    const tileLayers = {
      osm: L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap', maxZoom: 19 }),
      satellite: L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', { attribution: '© Esri', maxZoom: 19 })
    };

    const map = L.map('map', { center: [4.05, 9.70], zoom: 11, scrollWheelZoom: true });
    tileLayers.osm.addTo(map);

    let cluster = L.markerClusterGroup({ maxClusterRadius: 50 });
    map.addLayer(cluster);

    function makeIcon(color) {
      return L.divIcon({
        className: '',
        html: `<div style="width:18px;height:18px;background:${color};border:2.5px solid #fff;border-radius:50%;box-shadow:0 2px 6px rgba(0,0,0,0.4);"></div>`,
        iconSize: [18, 18], iconAnchor: [9, 9]
      });
    }

    function updateStats(data) {
      document.getElementById('stat-en-cours').textContent = data.filter(p => p.statut === 'en_cours').length;
      document.getElementById('stat-termines').textContent = data.filter(p => p.statut === 'terminé').length;
      document.getElementById('stat-planifies').textContent = data.filter(p => p.statut === 'planifié').length;
      document.getElementById('stat-suspendus').textContent = data.filter(p => p.statut === 'suspendu').length;
      document.getElementById('stat-total').textContent = data.length;
    }

    function addMarkers(data) {
      cluster.clearLayers();
      data.forEach(p => {
        if (!p.latitude || !p.longitude) return;
        const color = statusColors[p.statut] || '#007A3D';
        const budget = p.budget_actuel ? (Math.round(Number(p.budget_actuel) / 1000000) + 'M FCFA') : '—';
        const photoUrl = p.photo ? (p.photo.startsWith('http') ? p.photo : `/assets/uploads/${p.photo}`) : null;
        const photoHtml = photoUrl ? `<img src="${photoUrl}" style="width:100%;height:110px;object-fit:cover;border-radius:8px;margin-bottom:8px;" onerror="this.style.display='none'">` : '';
        const popup = `<div class="popup-inner">
          ${photoHtml}
          <div class="popup-title">${p.titre}</div>
          <span class="popup-badge" style="background:${color}22;color:${color};">${p.statut.replace('_',' ')}</span>
          <div style="font-size:11px;color:#64748B;margin:6px 0;">💰 ${budget}</div>
          <div class="popup-bar"><div class="popup-bar-fill" style="width:${p.avancement_physique||0}%;background:${color};"></div></div>
          <div style="font-size:11px;color:#64748B;margin-bottom:6px;">${p.avancement_physique||0}% réalisé</div>
          <a href="${siteUrl}/portail-citoyen/projet/${p.id}" class="popup-link">Voir le projet →</a>
        </div>`;
        cluster.addLayer(L.marker([p.latitude, p.longitude], { icon: makeIcon(color) }).bindPopup(popup, { maxWidth: 260 }));
      });
      if (cluster.getLayers().length) {
        try { map.fitBounds(cluster.getBounds().pad(0.15)); } catch(e) {}
      }
    }

    updateStats(projetsData);
    addMarkers(projetsData);

    document.getElementById('statutFilter').addEventListener('change', function() {
      const s = this.value;
      const filtered = s ? projetsData.filter(p => p.statut === s) : projetsData;
      addMarkers(filtered);
      updateStats(filtered);
    });

    function setLayer(name, el) {
      Object.values(tileLayers).forEach(l => map.removeLayer(l));
      tileLayers[name].addTo(map);
      document.querySelectorAll('.layer-pill').forEach(p => p.classList.remove('active'));
      el.classList.add('active');
    }
  </script>

</body>
</html>
