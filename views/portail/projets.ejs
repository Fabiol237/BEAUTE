<!DOCTYPE html>
<html lang="fr"><head><meta charset="UTF-8"><title>Projets — Portail</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head><body class="bg-light">
<nav class="navbar navbar-dark" style="background:#007A3D"><div class="container">
<a class="navbar-brand text-white" href="<%= siteUrl %>/portail-citoyen">Portail Citoyen</a>
<a class="nav-link text-white" href="<%= siteUrl %>/portail-citoyen/suggestion">Suggestions</a>
</div></nav>
<div class="container py-4">
<h1 class="mb-4">Projets municipaux</h1>
<form class="row g-2 mb-4" method="GET">
<div class="col-md-3"><input name="q" class="form-control" placeholder="Recherche" value="<%= e(recherche) %>"></div>

<div class="col-md-2"><select name="type" class="form-select"><option value="">Type</option>
<% types.forEach(t=>{ %><option value="<%= t.id %>" <%= String(type_id)===String(t.id)?'selected':'' %>><%= e(t.nom) %></option><% }); %></select></div>
<div class="col-md-2"><select name="statut" class="form-select"><option value="">Statut</option>
<% ['planifié','en_cours','terminé','suspendu'].forEach(s=>{ %><option value="<%= s %>" <%= statut===s?'selected':'' %>><%= s %></option><% }); %></select></div>
<div class="col-md-2"><button class="btn btn-primary w-100">Filtrer</button></div>
</form>
<div class="row g-3">
<% projets.forEach(p=>{ %>
<div class="col-md-6 col-lg-4"><div class="card h-100"><div class="card-body">
<h5><%= e(p.titre) %></h5>
<p class="small"><%= (p.description||'').substring(0,120) %>...</p>
<a href="<%= siteUrl %>/portail-citoyen/projet/<%= p.id %>" class="btn btn-success btn-sm">Voir</a>
</div></div></div>
<% }); %>
<% if (!projets.length) { %><p class="text-muted">Aucun projet.</p><% } %>
</div></div></body></html>
