<%- include('../partials/header', { page_title: 'Utilisateurs' }) %>
<%- include('../partials/navbar') %>
<div class="container-fluid mt-4">
<%- getFlash() %>
<div class="d-flex justify-content-between mb-4">
<h1><i class="bi bi-people-fill me-2"></i>Utilisateurs</h1>
<a href="<%= siteUrl %>/utilisateurs/ajouter" class="btn btn-primary">Nouvel utilisateur</a>
</div>
<div class="row mb-3">
<div class="col-md-3"><div class="card p-3">Total: <strong><%= stats.total %></strong></div>
<div class="col-md-3"><div class="card p-3">Actifs: <strong><%= stats.actifs %></strong></div></div>
<div class="col-md-3"><div class="card p-3">Admins: <strong><%= stats.admins %></strong></div></div>
<div class="col-md-3"><div class="card p-3">Inactifs: <strong><%= stats.inactifs %></strong></div></div>
</div>
<div class="card table-responsive"><table class="table mb-0">
<thead><tr><th>Nom</th><th>Email</th><th>Rôle</th><th>Statut</th><th>Créé</th><th></th></tr></thead>
<tbody>
<% utilisateurs.forEach(u => { %>
<tr>
<td><%= e(u.prenom+' '+u.nom) %></td>
<td><%= e(u.email) %></td>
<td><span class="badge bg-secondary"><%= e(u.role) %></span></td>
<td><% if (u.actif==1) { %><span class="badge bg-success">Actif</span><% } else { %><span class="badge bg-danger">Inactif</span><% } %></td>
<td><%= formatDate(u.date_inscription || u.created_at) %></td>
<td>
<a href="<%= siteUrl %>/utilisateurs/modifier/<%= u.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
<% if (u.id != session.utilisateur_id) { %>
<a href="<%= siteUrl %>/utilisateurs/supprimer/<%= u.id %>" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></a>
<% } %>
</td></tr>
</tbody></table></div>

<% if (session.utilisateur_role === 'super_admin') { %>
<div class="card mt-5 border-primary shadow-sm">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-link-45deg me-2"></i>Générateur de Liens d'Inscription par Commune</h5>
        <span class="badge bg-light text-primary py-2 px-3 fw-bold">Super Admin</span>
    </div>
    <div class="card-body">
        <p class="text-muted mb-4">
            <i class="bi bi-info-circle-fill text-primary me-2"></i>
            En tant que **Super Administrateur**, vous pouvez copier et transmettre le lien d'inscription unique ci-dessous au maire ou responsable de chaque commune. Ce lien sécurisé pré-sélectionne et verrouille le compte en tant qu'<strong>Administrateur</strong> pour cette commune spécifique.
        </p>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%;">Commune</th>
                        <th style="width: 15%;">Région</th>
                        <th style="width: 45%;">Lien d'Inscription Unique Sécurisé</th>
                        <th style="width: 15%; text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% communes.forEach(c => { %>
                    <tr>
                        <td class="fw-bold text-primary"><i class="bi bi-building me-2"></i><%= e(c.nom) %></td>
                        <td><span class="badge bg-secondary"><%= e(c.region) %></span></td>
                        <td>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control bg-light font-monospace text-muted" id="link-<%= c.id %>" value="<%= c.inscription_link %>" readonly>
                                <button class="btn btn-primary" type="button" onclick="copyLink('<%= c.id %>')">
                                    <i class="bi bi-clipboard me-1" id="icon-<%= c.id %>"></i>Copier
                                </button>
                            </div>
                        </td>
                        <td class="text-end">
                            <a href="<%= c.inscription_link %>" target="_blank" class="btn btn-sm btn-outline-success">
                                <i class="bi bi-box-arrow-up-right me-1"></i>Tester
                            </a>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function copyLink(id) {
    const copyText = document.getElementById("link-" + id);
    copyText.select();
    copyText.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(copyText.value).then(() => {
        const btnIcon = document.getElementById("icon-" + id);
        btnIcon.className = "bi bi-check-lg me-1";
        setTimeout(() => {
            btnIcon.className = "bi bi-clipboard me-1";
        }, 2000);
    });
}
</script>
<% } %>

</div>
<%- include('../partials/footer') %>
