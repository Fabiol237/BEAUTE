<%- include('partials/header', { page_title: 'Connexion — Espace Communes' }) %>

<style>
  .login-page {
    min-height: 100vh;
    display: flex;
    background: linear-gradient(135deg, #003F88 0%, #005CC8 50%, #007A3D 100%);
    position: relative;
    overflow: hidden;
  }
  .login-page::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M50 50c0-5.523 4.477-10 10-10s10 4.477 10 10-4.477 10-10 10c0 5.523-4.477 10-10 10s-10-4.477-10-10 4.477-10 10-10zM10 10c0-5.523 4.477-10 10-10s10 4.477 10 10-4.477 10-10 10c0 5.523-4.477 10-10 10S0 25.523 0 20s4.477-10 10-10z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .login-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px;
    position: relative;
    z-index: 1;
    color: white;
    text-align: center;
  }
  .login-right {
    width: 480px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px;
    position: relative;
    box-shadow: -20px 0 60px rgba(0,0,0,0.2);
  }
  .login-form-wrap { width: 100%; max-width: 380px; }
  .login-logo { width: 80px; height: 80px; object-fit: contain; background: white; padding: 12px; border-radius: 20px; margin-bottom: 24px; box-shadow: 0 8px 32px rgba(0,0,0,0.15); }
  .login-tagline { font-size: 2.2rem; font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
  .login-sub { font-size: 1.05rem; opacity: 0.85; max-width: 360px; }
  .feature-item { display: flex; align-items: center; gap: 12px; margin-top: 16px; text-align: left; background: rgba(255,255,255,0.12); border-radius: 12px; padding: 12px 16px; }
  .feature-icon { font-size: 20px; flex-shrink: 0; }
  .form-control-xl { padding: 14px 16px; font-size: 15px; border: 1.5px solid #e2e8f0; border-radius: 10px; transition: all .2s; }
  .form-control-xl:focus { border-color: #003F88; box-shadow: 0 0 0 3px rgba(0,63,136,.12); }
  .btn-login { background: linear-gradient(135deg, #003F88, #005CC8); color: white; border: none; border-radius: 10px; padding: 14px; font-size: 16px; font-weight: 700; width: 100%; transition: all .2s; }
  .btn-login:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,63,136,.35); }
  .super-admin-link { display: block; text-align: center; margin-top: 20px; font-size: 13px; color: #94a3b8; }
  .super-admin-link a { color: #003F88; font-weight: 600; text-decoration: none; }
  .super-admin-link a:hover { text-decoration: underline; }
  @media (max-width: 768px) {
    .login-left { display: none; }
    .login-right { width: 100%; }
  }
</style>

<div class="login-page">
  <!-- Gauche décorative -->
  <div class="login-left">
    <img src="/assets/images/logo.png" class="login-logo" alt="Logo">
    <div class="login-tagline">Suivi des Projets<br>Municipaux 🏛️</div>
    <p class="login-sub">Plateforme de gestion et de transparence des projets de développement des communes du Littoral Cameroun</p>
    
    <div style="margin-top:40px; width:100%; max-width:380px;">
      <div class="feature-item">
        <div class="feature-icon">📊</div>
        <div><strong>Tableaux de Bord</strong><br><small style="opacity:.8;">Suivez l'avancement en temps réel</small></div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">💰</div>
        <div><strong>Gestion Budgétaire</strong><br><small style="opacity:.8;">Contrôlez chaque dépense</small></div>
      </div>
      <div class="feature-item">
        <div class="feature-icon">🗺️</div>
        <div><strong>Carte Satellitaire</strong><br><small style="opacity:.8;">Visualisez les projets sur le terrain</small></div>
      </div>
    </div>

    <!-- Drapeaux Cameroun -->
    <div style="margin-top:40px; display:flex; gap:6px; align-items:center;">
      <div style="width:24px;height:16px;background:#007A3D;border-radius:2px;"></div>
      <div style="width:24px;height:16px;background:#CE1126;border-radius:2px;"></div>
      <div style="width:24px;height:16px;background:#FCD116;border-radius:2px;"></div>
      <small style="margin-left:8px;opacity:.8;">Cameroun · Région Littoral</small>
    </div>
  </div>

  <!-- Droite : Formulaire -->
  <div class="login-right">
    <div class="login-form-wrap">
      <div style="margin-bottom:32px;">
        <h2 style="font-size:24px;font-weight:800;color:#1e293b;margin:0;">Espace Communes</h2>
        <p style="color:#64748b;margin-top:6px;font-size:14px;">Connectez-vous pour accéder à votre tableau de bord</p>
      </div>

      <% if (erreur) { %>
      <div style="background:#fef2f2;border:1px solid #fecaca;border-radius:10px;padding:12px 16px;margin-bottom:24px;display:flex;gap:10px;align-items:flex-start;">
        <i class="bi bi-exclamation-circle-fill" style="color:#ef4444;flex-shrink:0;margin-top:2px;"></i>
        <span style="color:#b91c1c;font-size:14px;"><%= e(erreur) %></span>
      </div>
      <% } %>

      <form method="POST" action="/login">
        <div style="margin-bottom:20px;">
          <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
            <i class="bi bi-envelope me-1"></i>Adresse Email
          </label>
          <input type="email" name="email" class="form-control form-control-xl"
                 placeholder="votre@commune.cm"
                 value="<%= e(body.email || '') %>" required autofocus>
        </div>
        <div style="margin-bottom:28px;">
          <label style="font-size:13px;font-weight:600;color:#374151;display:block;margin-bottom:6px;">
            <i class="bi bi-lock me-1"></i>Mot de passe
          </label>
          <div style="position:relative;">
            <input type="password" id="login-password" name="password" class="form-control form-control-xl"
                   placeholder="••••••••" required style="padding-right: 40px;">
            <button type="button" onclick="togglePassword('login-password', this)" style="position:absolute; right:12px; top:50%; transform:translateY(-50%); background:none; border:none; color:#64748b; cursor:pointer; padding:0;">
              <i class="bi bi-eye"></i>
            </button>
          </div>
        </div>
        <button type="submit" class="btn-login">
          <i class="bi bi-box-arrow-in-right me-2"></i>Se connecter
        </button>
      </form>

      <div style="margin-top:24px;padding-top:20px;border-top:1px solid #f1f5f9;text-align:center;">
        <small style="color:#94a3b8;"><i class="bi bi-shield-check me-1"></i>Connexion sécurisée — Données chiffrées</small>
      </div>

      <div class="super-admin-link">
        Administration MuniPro ? <a href="/admin/login">Espace Super Admin →</a>
      </div>
    </div>
  </div>
</div>

<script>
function togglePassword(inputId, btn) {
  var input = document.getElementById(inputId);
  var icon = btn.querySelector('i');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.remove('bi-eye');
    icon.classList.add('bi-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.remove('bi-eye-slash');
    icon.classList.add('bi-eye');
  }
}
</script>

<%- include('partials/footer') %>
