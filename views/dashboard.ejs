<%- include('partials/header', { page_title: 'Dashboard' }) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-4">
    <%- typeof getFlash === 'function' ? getFlash() : '' %>

    <div class="page-header">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h1>
                    <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    <% if (is_super_admin) { %>
                    <span class="badge ms-2" style="background:#7c3aed;font-size:0.65rem;vertical-align:middle;"><i class="bi bi-shield-fill-check me-1"></i>Super Admin MuniPro</span>
                    <% } else if (commune_info) { %>
                    <span class="badge bg-primary ms-2" style="font-size:0.65rem;vertical-align:middle;"><i class="bi bi-building me-1"></i><%= e(commune_info.nom) %></span>
                    <% } %>
                </h1>
                <p class="text-muted mb-0">
                    Bienvenue, <strong><%= typeof session !== 'undefined' ? e(session.utilisateur_prenom) : 'Admin' %></strong> !
                    <% if (!is_super_admin && commune_info) { %>
                    <span class="badge ms-2" style="background:<%= session.utilisateur_role === 'admin' ? '#7c3aed' : session.utilisateur_role === 'gestionnaire' ? '#0891b2' : '#6b7280' %>;font-size:0.65rem;">
                      <% if (session.utilisateur_role === 'admin') { %>👑 Administrateur<% } else if (session.utilisateur_role === 'gestionnaire') { %>🛠️ Gestionnaire<% } else { %>👁️ Lecteur<% } %>
                    </span>
                    <% } %>
                    <span class="ms-2"><i class="bi bi-calendar3 me-1"></i><%= typeof todayFr === 'function' ? todayFr() : new Date().toLocaleDateString('fr-FR') %></span>
                </p>
            </div>
            <div class="d-flex flex-wrap gap-2">
              <% if (!is_super_admin && commune_info) { %>
              <a href="/utilisateurs/journal" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-clock-history me-1"></i>Journal
              </a>
              <% } %>
              <% if (!is_super_admin && session.utilisateur_role !== 'lecteur') { %>
              <a href="<%= siteUrl %>/projets/creer" class="btn btn-primary">
                  <i class="bi bi-plus-circle me-2"></i>Nouveau projet
              </a>
              <% } else if (is_super_admin) { %>
              <a href="/super-admin/comptes" class="btn btn-outline-secondary">
                  <i class="bi bi-people-fill me-2"></i>Gérer les comptes
              </a>
              <% } %>
            </div>
        </div>
    </div>

    <% if (!is_super_admin && commune_info) { %>
    <!-- BANNIÈRE COMMUNE -->
    <div class="d-flex flex-column flex-md-row align-items-center align-items-md-center gap-3 p-3 p-md-4 mb-4 text-center text-md-start" style="background:linear-gradient(135deg,#003F88,#0a5ebd);border-radius:12px;">
      <div style="background:rgba(255,255,255,0.15);border-radius:10px;padding:12px;flex-shrink:0;">
        <i class="bi bi-building" style="font-size:28px;color:white;"></i>
      </div>
      <div class="flex-grow-1">
        <div style="color:rgba(255,255,255,0.7);font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;">Espace de Travail</div>
        <div style="color:white;font-size:20px;font-weight:800;"><%= e(commune_info.nom) %></div>
        <div style="color:rgba(255,255,255,0.8);font-size:13px;">Région <%= e(commune_info.region) %> · Responsable : <%= e(commune_info.responsable || '—') %></div>
      </div>
      <div class="text-center text-md-end mt-2 mt-md-0">
        <div style="color:rgba(255,255,255,0.7);font-size:11px;">Connecté en tant que</div>
        <div style="color:white;font-weight:700;"><%= e(session.utilisateur_prenom) %> <%= e(session.utilisateur_nom) %></div>
        <div style="background:rgba(255,255,255,0.2);color:white;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600;margin-top:4px;display:inline-block;">
          <% if (session.utilisateur_role === 'admin') { %>👑 Administrateur<% } else if (session.utilisateur_role === 'gestionnaire') { %>🛠️ Gestionnaire<% } else { %>👁️ Lecteur<% } %>
        </div>
      </div>
    </div>
    <% } %>

    <% if (stats && stats.depenses_attente > 0) { %>
    <div class="alert alert-warning d-flex align-items-center mb-4">
        <i class="bi bi-exclamation-circle-fill me-2"></i>
        <div>
            <strong><%= stats.depenses_attente %> dépense(s)</strong> en attente de validation —
            non incluses dans les totaux ci-dessous.
            <a href="<%= siteUrl %>/budget/liste" class="alert-link ms-2">Voir →</a>
        </div>
    </div>
    <% } %>

    <!-- Ligne 1 : stats projets -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Total Projets</p>
                            <h3 class="fw-bold mb-0"><%= stats.total_projets || 0 %></h3>
                        </div>
                        <div class="stat-icon text-primary"><i class="bi bi-folder"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">En cours</p>
                            <h3 class="fw-bold mb-0 text-primary"><%= stats.projets_en_cours || 0 %></h3>
                            <% if (stats.projets_retard > 0) { %>
                            <small class="text-danger"><i class="bi bi-exclamation-circle me-1"></i><%= stats.projets_retard %> en retard</small>
                            <% } %>
                        </div>
                        <div class="stat-icon text-primary"><i class="bi bi-clock-history"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Budget Total</p>
                            <h3 class="fw-bold mb-0 text-warning"><%= ((stats.budget_total || 0) / 1000000).toFixed(1) %>M</h3>
                            <small class="text-muted">FCFA</small>
                        </div>
                        <div class="stat-icon text-warning"><i class="bi bi-cash-stack"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Terminés</p>
                            <h3 class="fw-bold mb-0 text-success"><%= stats.projets_termines || 0 %></h3>
                        </div>
                        <div class="stat-icon text-success"><i class="bi bi-check-circle"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if (is_super_admin) { %>
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card" style="border-left:4px solid #7c3aed;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Communes</p>
                            <h3 class="fw-bold mb-0" style="color:#7c3aed;"><%= stats.total_communes || 0 %></h3>
                        </div>
                        <div class="stat-icon" style="color:#7c3aed;"><i class="bi bi-building"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card stat-card" style="border-left:4px solid #0891b2;">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Admins Actifs</p>
                            <h3 class="fw-bold mb-0 text-info"><%= stats.total_admins || 0 %></h3>
                        </div>
                        <div class="stat-icon text-info"><i class="bi bi-person-badge-fill"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-6 col-md-12 mb-4">
            <div class="card" style="border-left:4px solid #7c3aed;">
                <div class="card-body d-flex align-items-center">
                    <i class="bi bi-shield-fill-check me-3" style="font-size:2rem;color:#7c3aed;"></i>
                    <div>
                        <p class="mb-1 fw-bold" style="color:#7c3aed;">Mode Super Administrateur MuniPro</p>
                        <small class="text-muted">Vous supervisez l'ensemble de la plateforme. Les données couvrent toutes les communes. Le tableau de gestion et les liens d'inscription sont en bas de cette page.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <% } %>

    <!-- Ligne 2 : stats financières -->
    <div class="row mb-4">
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Dépenses Validées</p>
                            <h3 class="fw-bold mb-0 text-danger"><%= ((stats.depenses_total || 0) / 1000000).toFixed(1) %>M</h3>
                            <small class="text-muted">FCFA</small>
                        </div>
                        <div class="stat-icon text-danger"><i class="bi bi-graph-down-arrow"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Budget Restant</p>
                            <h3 class="fw-bold mb-0 <%= (stats.budget_restant || 0) < 0 ? 'text-danger' : 'text-success' %>">
                                <%= ((stats.budget_restant || 0) / 1000000).toFixed(1) %>M
                            </h3>
                            <small class="text-muted">FCFA</small>
                        </div>
                        <div class="stat-icon text-success"><i class="bi bi-piggy-bank"></i></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4 col-md-6 mb-4">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 text-uppercase small">Consommation</p>
                            <h3 class="fw-bold mb-0 text-primary"><%= stats.taux_consommation || 0 %>%</h3>
                            <div class="progress mt-1" style="height:6px; width:80px;">
                                <div class="progress-bar <%= (stats.taux_consommation || 0) > 80 ? 'bg-danger' : ((stats.taux_consommation || 0) > 50 ? 'bg-warning' : 'bg-success') %>"
                                     style="width:<%= Math.min(stats.taux_consommation || 0, 100) %>%"></div>
                            </div>
                        </div>
                        <div class="stat-icon text-primary"><i class="bi bi-percent"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphiques -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-pie-chart-fill me-2"></i>Répartition par Statut</h5></div>
                <div class="card-body"><canvas id="projetStatutChart" height="300"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Budget par Type</h5></div>
                <div class="card-body"><canvas id="budgetTypeChart" height="300"></canvas></div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-lg-12 mb-4">
            <div class="card">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-graph-up-arrow me-2"></i>Évolution Mensuelle</h5></div>
                <div class="card-body"><canvas id="evolutionChart" height="300"></canvas></div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12 mb-3">
            <a href="<%= siteUrl %>/carte" class="btn btn-success">
                <i class="bi bi-map me-2"></i>Voir la carte
            </a>
        </div>

        <div class="col-lg-8 mb-4">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-folder-fill me-2"></i>Derniers projets</h5>
                    <a href="<%= siteUrl %>/projets/liste" class="btn btn-sm btn-outline-primary">Voir tout <i class="bi bi-arrow-right ms-1"></i></a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead><tr><th>Projet</th><th>Budget</th><th>Avancement</th><th>Statut</th><th></th></tr></thead>
                            <tbody>
                                <% if (derniers_projets && derniers_projets.length > 0) { %>
                                <% derniers_projets.forEach(projet => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="rounded-circle p-2 me-2" style="background-color:<%= e(projet.couleur) %>20">
                                                <i class="bi bi-folder" style="color:<%= e(projet.couleur) %>"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold"><%= e(projet.titre) %></div>
                                                <small class="text-muted"><%= e(projet.type_nom) %></small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-nowrap"><%= typeof formatMontant === 'function' ? formatMontant(projet.budget_actuel) : projet.budget_actuel %></td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height:6px;width:80px;">
                                                <div class="progress-bar <%= typeof getProgressClass === 'function' ? getProgressClass(projet.avancement_physique) : 'bg-primary' %>" style="width:<%= projet.avancement_physique %>%"></div>
                                            </div>
                                            <small class="text-muted"><%= projet.avancement_physique %>%</small>
                                        </div>
                                    </td>
                                    <td><%- typeof getStatutBadge === 'function' ? getStatutBadge(projet.statut) : projet.statut %></td>
                                    <td><a href="<%= siteUrl %>/projets/details/<%= projet.id %>" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye"></i></a></td>
                                </tr>
                                <% }); %>
                                <% } else { %>
                                <tr><td colspan="6" class="text-center text-muted py-4"><i class="bi bi-inbox fs-1 d-block mb-2"></i>Aucun projet</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 mb-4">
            <div class="card border-warning">
                <div class="card-header bg-warning text-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Alertes (<%= projets_retard ? projets_retard.length : 0 %>)</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        <% if (projets_retard && projets_retard.length > 0) { %>
                        <% projets_retard.forEach(projet => { %>
                        <a href="<%= siteUrl %>/projets/details/<%= projet.id %>" class="list-group-item list-group-item-action">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <h6 class="mb-1"><%= e(projet.titre) %></h6>
                                </div>
                                <span class="badge bg-danger"><%= typeof joursRestants === 'function' ? Math.abs(joursRestants(projet.date_fin_prevue)) : 0 %> j</span>
                            </div>
                        </a>
                        <% }); %>
                        <% } else { %>
                        <div class="list-group-item text-center text-muted py-4">
                            <i class="bi bi-check-circle fs-1 text-success d-block mb-2"></i>Aucun projet en retard !
                        </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<% if (is_super_admin && communes_stats && communes_stats.length > 0) { %>
<div class="container-fluid mb-5">
    <div class="card shadow-sm" style="border-top:4px solid #7c3aed;">
        <div class="card-header d-flex justify-content-between align-items-center" style="background:linear-gradient(135deg,#7c3aed,#6d28d9);color:white;">
            <h5 class="mb-0"><i class="bi bi-building me-2"></i>Gestion des Communes — Liens d'Inscription Administrateurs</h5>
            <span class="badge bg-light text-dark px-3 py-2"><%= communes_stats.length %> communes</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Commune</th>
                            <th>Région</th>
                            <th class="text-center">Projets</th>
                            <th class="text-center">Budget</th>
                            <th class="text-center">Admin</th>
                            <th class="text-center">Dern. connexion</th>
                            <th style="width:340px;">Lien d'Inscription</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% communes_stats.forEach(c => { %>
                    <tr>
                        <td class="fw-bold"><i class="bi bi-building me-2 text-primary"></i><%= e(c.nom) %></td>
                        <td><span class="badge bg-secondary"><%= e(c.region) %></span></td>
                        <td class="text-center">
                            <span class="badge bg-primary"><%= Number(c.projets_en_cours) %> en cours</span>
                            <small class="text-muted ms-1">/ <%= Number(c.nb_projets) %></small>
                        </td>
                        <td class="text-center text-nowrap fw-bold text-warning">
                            <%= ((Number(c.budget_total)||0)/1000000).toFixed(1) %>M FCFA
                        </td>
                        <td class="text-center">
                            <% if (c.has_admin) { %>
                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i><%= Number(c.nb_admins) %> admin(s)</span>
                            <% } else { %>
                            <span class="badge bg-danger"><i class="bi bi-exclamation-circle me-1"></i>Aucun admin</span>
                            <% } %>
                        </td>
                        <td class="text-center">
                            <small class="text-muted">
                                <% if (c.derniere_connexion_admin) { %>
                                    <%= formatDate(c.derniere_connexion_admin) %>
                                <% } else { %>
                                    <span class="text-danger">Jamais</span>
                                <% } %>
                            </small>
                        </td>
                        <td>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control font-monospace bg-light text-muted"
                                    id="lnk-<%= c.id %>" value="<%= c.inscription_link %>" readonly>
                                <button class="btn btn-outline-primary" type="button"
                                    onclick="copyInscriptionLink('<%= c.id %>')" title="Copier le lien">
                                    <i class="bi bi-clipboard" id="ico-<%= c.id %>"></i>
                                </button>
                                <a href="<%= c.inscription_link %>" target="_blank"
                                    class="btn btn-outline-success" title="Tester le lien">
                                    <i class="bi bi-box-arrow-up-right"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                    <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer text-muted small bg-light">
            <i class="bi bi-info-circle-fill text-primary me-2"></i>
            Copiez et envoyez le lien correspondant au responsable de chaque commune. Ce lien sécurisé crée directement un compte Administrateur lié à la commune.
        </div>
    </div>
</div>

<script>
function copyInscriptionLink(id) {
    const el = document.getElementById('lnk-' + id);
    el.select(); el.setSelectionRange(0, 99999);
    navigator.clipboard.writeText(el.value).then(() => {
        const ico = document.getElementById('ico-' + id);
        ico.className = 'bi bi-check-lg text-success';
        setTimeout(() => { ico.className = 'bi bi-clipboard'; }, 2000);
    });
}
</script>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
const colors = { primary:'#2563eb', success:'#10b981', warning:'#f59e0b', danger:'#ef4444', info:'#3b82f6' };
<% if (projets_statut && projets_statut.length > 0) { %>
new Chart(document.getElementById('projetStatutChart'), { type:'doughnut', data:{ labels:<%- JSON.stringify(projets_statut.map(x=>x.statut_label)) %>, datasets:[{ data:<%- JSON.stringify(projets_statut.map(x=>x.nombre)) %>, backgroundColor:[colors.info,colors.primary,colors.success,colors.warning,colors.danger], borderWidth:0 }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{legend:{position:'bottom'}} } });
<% } %>
<% if (budget_types && budget_types.length > 0) { %>
new Chart(document.getElementById('budgetTypeChart'), { type:'bar', data:{ labels:<%- JSON.stringify(budget_types.map(x=>x.type)) %>, datasets:[{ label:'Budget (M FCFA)', data:<%- JSON.stringify(budget_types.map(x=>Math.round(x.budget_total/100000)/10)) %>, backgroundColor:<%- JSON.stringify(budget_types.map(x=>x.couleur || '#ccc')) %>, borderRadius:8, borderSkipped:false }] }, options:{ indexAxis:'y', responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{x:{beginAtZero:true,ticks:{callback:v=>v+'M'}}} } });
<% } %>
<% if (evolution_projets && evolution_projets.length > 0) { %>
new Chart(document.getElementById('evolutionChart'), { type:'line', data:{ labels:<%- JSON.stringify(evolution_projets.map(x=>x.mois)) %>, datasets:[{ label:'Nouveaux projets', data:<%- JSON.stringify(evolution_projets.map(x=>x.nombre)) %>, borderColor:colors.primary, backgroundColor:colors.primary+'20', fill:true, tension:0.4, pointBackgroundColor:colors.primary, pointBorderColor:'#fff', pointBorderWidth:2, pointRadius:4, pointHoverRadius:6 }] }, options:{ responsive:true, maintainAspectRatio:false, plugins:{legend:{display:false}}, scales:{y:{beginAtZero:true,ticks:{stepSize:1}}} } });
<% } %>
</script>

<%- include('partials/footer') %>
