<%- include('../partials/header', { page_title: 'Détails du projet' }) %>
<%- include('../partials/navbar') %>
<div class="container-fluid mt-4">
<%- getFlash() %>
<% if (projet.photo) { %>
<div class="card mb-4 border-0 shadow-sm overflow-hidden">
  <div style="height: 250px; background-image: url('/assets/uploads/<%= e(projet.photo) %>'); background-size: cover; background-position: center; position: relative;">
    <div style="position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0.1));"></div>
    <div style="position: absolute; bottom: 0; left: 0; right: 0; padding: 20px; color: white;">
      <span class="badge" style="background:<%= e(projet.type_couleur || '#6c757d') %>"><%= e(projet.type_nom) %></span>
      <h1 class="mt-2 mb-1 text-white" style="text-shadow: 1px 1px 3px rgba(0,0,0,0.5);"><%= e(projet.titre) %></h1>
      <p class="mb-0 text-light"><i class="bi bi-geo-alt"></i> <% if (projet.region_nom) { %><%= e(projet.region_nom) %> - <% } %><%= e(projet.commune_nom) %></p>
    </div>
  </div>
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <%- getStatutBadge(projet.statut) %>
      <% if (projet.description) { %><p class="mt-2 mb-0 text-muted"><%= e(projet.description) %></p><% } %>
    </div>
    <div class="text-end" style="min-width: 150px;">
      <a href="<%= siteUrl %>/projets/modifier/<%= projet.id %>" class="btn btn-primary mb-2 w-100">Modifier</a><br>
      <a href="<%= siteUrl %>/projets/liste" class="btn btn-outline-secondary btn-sm w-100">Retour</a>
    </div>
  </div>
</div>
<% } else { %>
<div class="card mb-4" style="border-left:5px solid <%= e(projet.type_couleur || '#6c757d') %>">
<div class="card-body">
<div class="d-flex justify-content-between">
<div>
<span class="badge" style="background:<%= e(projet.type_couleur || '#6c757d') %>"><%= e(projet.type_nom) %></span>
<%- getStatutBadge(projet.statut) %>
<h1 class="mt-2"><%= e(projet.titre) %></h1>
<p class="text-muted"><i class="bi bi-geo-alt"></i> <% if (projet.region_nom) { %><%= e(projet.region_nom) %><% } %></p>
</div>
<div class="text-end">
<a href="<%= siteUrl %>/projets/modifier/<%= projet.id %>" class="btn btn-primary mb-2">Modifier</a><br>
<a href="<%= siteUrl %>/projets/liste" class="btn btn-outline-secondary btn-sm">Retour</a>
</div></div>
<% if (projet.description) { %><p class="mt-3"><%= e(projet.description) %></p><% } %>
</div></div>
<% } %>
<div class="row">
<div class="col-lg-8">
<div class="card mb-4"><div class="card-header">Avancement</div>
<div class="card-body">
<div class="row">
<div class="col-md-6"><h2><%= projet.avancement_physique %>%</h2>
<div class="progress" style="height:12px"><div class="progress-bar <%= getProgressClass(projet.avancement_physique) %>" style="width:<%= projet.avancement_physique %>%"></div></div></div>
<div class="col-md-6"><h2><%= Math.round(pourcentage_temps) %>%</h2><small class="text-muted"><%= jours_ecoules %> / <%= duree_totale %> jours</small></div>
</div>
<% if (liste_avancements.length) { %>
<div class="list-group mt-3">
<% liste_avancements.forEach(a => { %>
<div class="list-group-item"><span class="badge bg-primary"><%= a.pourcentage %>%</span> <%= formatDate(a.date_constat) %> — <%= e(a.auteur) %>
<% if (a.description) { %><p class="small mb-0"><%= e(a.description) %></p><% } %></div>
<% }); %></div>
<% } else { %><p class="text-muted">Aucune mise à jour</p><% } %>
<button class="btn btn-primary mt-2" data-bs-toggle="modal" data-bs-target="#modalAvancement">Mettre à jour</button>
</div></div>
<div class="card mb-4"><div class="card-header">Budget</div><div class="card-body">
<div class="row g-3 mb-3">
<div class="col-md-4"><small class="text-muted">Initial</small><h4><%= formatMontant(projet.budget_previsionnel) %></h4></div>
<div class="col-md-4"><small class="text-muted">Dépenses</small><h4><%= formatMontant(depenses) %></h4></div>
<div class="col-md-4"><small class="text-muted">Reste</small><h4><%= formatMontant(budget_restant) %></h4></div>
</div>
<div class="progress" style="height:20px"><div class="progress-bar" style="width:<%= Math.min(taux_consommation,100) %>%"><%= Math.round(taux_consommation) %>%</div></div>
<a href="<%= siteUrl %>/budget/liste?projet=<%= projet.id %>" class="btn btn-outline-primary me-2">Détail budget</a>
<a href="<%= siteUrl %>/budget/depenses?projet_id=<%= projet.id %>" class="btn btn-primary">Ajouter dépense</a>
</div></div>
<div class="card mb-4"><div class="card-header">Photos</div><div class="card-body">
<% if (liste_photos.length) { %><div class="row g-2"><% liste_photos.forEach(ph => { %>
<div class="col-md-4"><img src="/assets/uploads/<%= e(ph.fichier_url) %>" class="img-fluid rounded" alt=""></div>
<% }); %></div><% } else { %><p class="text-muted">Aucune photo</p><% } %>
<a href="<%= siteUrl %>/projets/upload-photos/<%= projet.id %>" class="btn btn-primary mt-2">Ajouter photos</a>
</div></div>
</div>
<div class="col-lg-4">
<div class="card mb-4"><div class="card-header bg-primary text-white">Informations</div><div class="card-body">
<p><strong>Début :</strong> <%= formatDate(projet.date_debut) %></p>
<p><strong>Fin prévue :</strong> <%= formatDate(projet.date_fin_prevue) %></p>
<% if (jours_restants !== null) { %><p><strong>Jours restants :</strong> <%= jours_restants < 0 ? 'Retard '+Math.abs(jours_restants)+'j' : jours_restants+' j' %></p><% } %>
<p><strong>Responsable :</strong> <%= e(projet.responsable_nom) %></p>
<% if (projet.adresse) { %><p><strong>Adresse :</strong> <%= e(projet.adresse) %></p><% } %>
</div></div>
<div class="card"><div class="card-header">Actions</div><div class="card-body d-grid gap-2">
<a href="<%= siteUrl %>/projets/rapports/<%= projet.id %>" class="btn btn-outline-primary">Rapports PDF</a>
<a href="<%= siteUrl %>/projets/generer-rapport/<%= projet.id %>?type=complet" class="btn btn-outline-secondary" target="_blank">Télécharger rapport complet</a>
<% if ((session.utilisateur_role||'')==='admin') { %>
<a href="<%= siteUrl %>/projets/supprimer/<%= projet.id %>" class="btn btn-outline-danger">Supprimer</a>
<% } %>
</div></div>
</div></div>
</div>
<div class="modal fade" id="modalAvancement"><div class="modal-dialog"><form method="POST" action="/projets/details/<%= projet_id %>" class="modal-content">
<input type="hidden" name="action" value="update_avancement">
<div class="modal-header bg-primary text-white"><h5 class="modal-title">Mettre à jour l'avancement</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
<div class="modal-body">
<label class="form-label">Pourcentage</label>
<input type="range" name="pourcentage" class="form-range" min="0" max="100" step="5" value="<%= projet.avancement_physique %>" oninput="document.getElementById('valAv').textContent=this.value+'%'">
<span id="valAv"><%= projet.avancement_physique %>%</span>
<label class="form-label mt-2">Date</label><input type="date" name="date_constat" class="form-control" value="<%= todayIso() %>" required>
<label class="form-label mt-2">Description</label><input type="text" name="description" class="form-control">
<label class="form-label mt-2">Observations</label><textarea name="observations" class="form-control" rows="2"></textarea>
</div>
<div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Annuler</button><button type="submit" class="btn btn-primary">Enregistrer</button></div>
</form></div></div>
<%- include('../partials/footer') %>
