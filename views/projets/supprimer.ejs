<%- include('../partials/header', { page_title: 'Supprimer le projet' }) %>
<%- include('../partials/navbar') %>
<div class="container-fluid mt-4">
<div class="row justify-content-center">
<div class="col-lg-6">
<div class="card border-danger">
<div class="card-header bg-danger text-white"><h4 class="mb-0">Confirmer la suppression</h4></div>
<div class="card-body">
<div class="alert alert-danger"><strong>Action irréversible !</strong> Toutes les données associées seront supprimées.</div>
<p class="fw-bold text-danger fs-5"><%= e(projet.titre) %></p>
<form method="POST">
<button type="submit" name="confirmer" value="1" class="btn btn-danger btn-lg w-100 mb-2">Oui, supprimer</button>
<a href="<%= siteUrl %>/projets/details/<%= projet_id %>" class="btn btn-outline-secondary btn-lg w-100">Annuler</a>
</form>
</div></div></div></div></div>
<%- include('../partials/footer') %>
