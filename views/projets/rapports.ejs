<%- include('../partials/header', { page_title: 'Générer un rapport' }) %>
<%- include('../partials/navbar') %>
<div class="container-fluid mt-4">
<div class="page-header mb-4 d-flex justify-content-between">
<div><h1><i class="bi bi-file-earmark-pdf me-2"></i>Rapports</h1><p class="text-muted"><%= e(projet.titre) %></p></div>
<a href="<%= siteUrl %>/projets/details/<%= projet_id %>" class="btn btn-outline-secondary">Retour</a>
</div>
<div class="col-lg-8 mx-auto">
<div class="alert alert-info">Le PDF sera téléchargé automatiquement.</div>
<% [['complet','Rapport complet','primary'],['financier','Rapport financier','success'],['avancement',"Rapport d'avancement",'warning']].forEach(([t,l,c]) => { %>
<div class="card mb-3"><div class="card-body d-flex justify-content-between align-items-center">
<div><h5><%= l %></h5></div>
<a href="<%= siteUrl %>/projets/generer-rapport/<%= projet_id %>?type=<%= t %>" class="btn btn-<%= c %>" target="_blank"><i class="bi bi-download me-2"></i>Générer</a>
</div></div>
<% }); %>
</div></div>
<%- include('../partials/footer') %>
