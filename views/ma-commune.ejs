<%- include('partials/header') %>
<%- include('partials/navbar') %>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color:var(--vert-dark);">Paramètres de ma Commune</h2>
            <p class="text-muted mb-0">Modifiez les informations et la bannière de votre commune</p>
        </div>
    </div>

    <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success"><%= message %></div>
    <% } %>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form action="/dashboard/ma-commune" method="POST" enctype="multipart/form-data">
                
                <div class="mb-4">
                    <label class="form-label fw-bold">Bannière actuelle</label>
                    <div class="mb-2">
                        <img id="bannerPreview" src="<%= (commune && commune.banniere) ? commune.banniere : '' %>" alt="Bannière"
                             style="max-height: 200px; border-radius: 8px; object-fit: cover; width: 100%; <%= (commune && commune.banniere) ? '' : 'display:none;' %>">
                        <div id="defaultBannerPlaceholder" class="bg-light p-4 text-center rounded text-muted"
                             style="<%= (commune && commune.banniere) ? 'display:none;' : '' %>">
                            <i class="bi bi-image" style="font-size:40px;display:block;margin-bottom:8px;opacity:0.4;"></i>
                            Aucune bannière personnalisée. L'image par défaut sera utilisée.
                        </div>
                    </div>
                    <label class="form-label fw-bold mt-3">Changer la bannière</label>
                    <input type="file" name="banniere" class="form-control" accept="image/*"
                           onchange="if(this.files[0]){var p=document.getElementById('bannerPreview');var d=document.getElementById('defaultBannerPlaceholder');var createUrl=window.URL&&window.URL.createObjectURL?window.URL.createObjectURL.bind(window.URL):null; if(createUrl){var url=createUrl(this.files[0]); p.src=url; p.style.display='block'; if(d)d.style.display='none';}}">
                    <small class="text-muted">Format recommandé : Paysage, JPG/PNG, max 2Mo</small>
                </div>

                <!-- Image principale de la commune (Cloudinary) -->
                <div class="mb-4">
                    <label class="form-label fw-bold">🖼️ Image de la Commune</label>
                    <div class="mb-2">
                        <% if (commune && commune.image_url) { %>
                            <img id="imagePreview" src="<%= commune.image_url %>" alt="Image commune"
                                 style="max-height: 300px; border-radius: 8px; object-fit: cover; width: 100%; display:block;">
                        <% } else { %>
                            <div id="defaultImagePlaceholder" class="bg-light p-4 text-center rounded text-muted">
                                <i class="bi bi-building" style="font-size:40px;display:block;margin-bottom:8px;opacity:0.4;"></i>
                                Aucune image principale. Une image par défaut sera utilisée.
                            </div>
                        <% } %>
                    </div>
                    <label class="form-label fw-bold mt-3">Changer l'image de la commune</label>
                    <input type="file" name="image_commune" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp"
                           onchange="if(this.files[0]){var p=document.getElementById('imagePreview');var d=document.getElementById('defaultImagePlaceholder');var createUrl=window.URL&&window.URL.createObjectURL?window.URL.createObjectURL.bind(window.URL):null; if(!createUrl) return; var url=createUrl(this.files[0]); p=p||document.createElement('img'); p.src=url; p.style.maxHeight='300px'; p.style.borderRadius='8px'; p.style.objectFit='cover'; p.style.width='100%'; p.id='imagePreview'; p.style.display='block'; if(d)d.style.display='none'; if(!document.getElementById('imagePreview')){d.parentNode.insertBefore(p,d);} else { document.getElementById('imagePreview').src=url; }}">
                    <small class="text-muted">Format: JPEG, PNG, GIF ou WebP. Max 50 MB</small>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Nom de la Commune</label>
                        <input type="text" name="nom" class="form-control" value="<%= commune.nom %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Région</label>
                        <input type="text" class="form-control" value="<%= commune.region %>" disabled>
                        <small class="text-muted">Contactez le Super Admin pour modifier la région.</small>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Email de contact</label>
                        <input type="email" name="email" class="form-control" value="<%= commune.email %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold">Téléphone de contact</label>
                        <input type="text" name="telephone" class="form-control" value="<%= commune.telephone %>">
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Nom du Responsable (Maire)</label>
                    <input type="text" name="responsable" class="form-control" value="<%= commune.responsable %>">
                </div>

                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-2"></i> Enregistrer les modifications</button>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
